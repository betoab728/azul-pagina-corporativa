---
interface Props {
  image: string
  imageAlt: string
  sector: string
  sectorColor: 'primary' | 'secondary'
  title: string
  description: string
  href?: string
  cta?: string
}

const { image, imageAlt, sector, sectorColor, title, description, href = '#', cta = 'Ver proyecto' } = Astro.props

const badgeColor = sectorColor === 'primary' ? 'bg-primary' : 'bg-secondary'
---

<article class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-outline-variant/30">
  <div class="relative h-48">
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover"
      loading="lazy"
      width="400"
      height="192"
    />
    <span class={`absolute top-4 left-4 ${badgeColor} text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase`}>
      {sector}
    </span>
  </div>
  <div class="p-6">
    <h4 class="font-bold text-lg mb-3 leading-tight">{title}</h4>
    <p class="text-on-surface-variant text-xs mb-6">{description}</p>
    <a href={href} class="text-primary font-bold text-xs flex items-center gap-2">
      {cta}
      <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span>
    </a>
  </div>
</article>
