---
import type { SupportedLocale } from '../../i18n/utils'
import { useTranslations } from '../../i18n/utils'

interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<div class="bg-white p-10 md:p-12 rounded-[40px] shadow-2xl border border-outline-variant/20 relative">
  <div class="flex items-center gap-4 mb-8">
    <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white">
      <span class="material-symbols-outlined" aria-hidden="true">fact_check</span>
    </div>
    <div>
      <h3 class="font-headline text-xl font-bold">{t('form.quote_title')}</h3>
      <p class="text-sm text-on-surface-variant">{t('form.quote_subtitle')}</p>
    </div>
  </div>

  <form id="quote-form" class="space-y-5" novalidate>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Nombre -->
      <div>
        <label for="quote-name" class="block text-sm font-bold mb-2">{t('form.name')} <span aria-hidden="true">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant/50 text-lg pointer-events-none" aria-hidden="true">person</span>
          <input
            id="quote-name"
            name="name"
            type="text"
            required
            placeholder={t('form.name_placeholder')}
            class="w-full pl-12 pr-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all"
          />
        </div>
      </div>

      <!-- Empresa -->
      <div>
        <label for="quote-company" class="block text-sm font-bold mb-2">{t('form.company_org')} <span aria-hidden="true">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant/50 text-lg pointer-events-none" aria-hidden="true">business</span>
          <input
            id="quote-company"
            name="company"
            type="text"
            required
            placeholder={t('form.company_placeholder')}
            class="w-full pl-12 pr-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all"
          />
        </div>
      </div>
    </div>

    <!-- Sector -->
    <div>
      <label for="quote-sector" class="block text-sm font-bold mb-2">{t('form.sector')} <span aria-hidden="true">*</span></label>
      <select
        id="quote-sector"
        name="sector"
        required
        class="w-full px-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all appearance-none cursor-pointer"
      >
        <option value="">{t('form.sector_placeholder')}</option>
        <option value="mineria">{t('form.sector_mining')}</option>
        <option value="industrial">{t('form.sector_industrial')}</option>
        <option value="salud">{t('form.sector_health')}</option>
        <option value="agroindustrial">{t('form.sector_agro')}</option>
      </select>
    </div>

    <!-- Desafío ambiental -->
    <div>
      <label for="quote-challenge" class="block text-sm font-bold mb-2">{t('form.challenge')} <span aria-hidden="true">*</span></label>
      <select
        id="quote-challenge"
        name="challenge"
        required
        class="w-full px-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all appearance-none cursor-pointer"
      >
        <option value="">{t('form.challenge_placeholder')}</option>
        <option value="residuos">{t('form.challenge_waste')}</option>
        <option value="aguas">{t('form.challenge_water')}</option>
        <option value="consultoria">{t('form.challenge_consulting')}</option>
        <option value="otros">{t('form.challenge_other')}</option>
      </select>
    </div>

    <!-- Email -->
    <div>
      <label for="quote-email" class="block text-sm font-bold mb-2">{t('form.email')} <span aria-hidden="true">*</span></label>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant/50 text-lg pointer-events-none" aria-hidden="true">mail</span>
        <input
          id="quote-email"
          name="email"
          type="email"
          required
          placeholder="ejemplo@empresa.com"
          class="w-full pl-12 pr-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all"
        />
      </div>
    </div>

    <!-- Teléfono -->
    <div>
      <label for="quote-phone" class="block text-sm font-bold mb-2">{t('form.phone_whatsapp')} <span aria-hidden="true">*</span></label>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant/50 text-lg pointer-events-none" aria-hidden="true">call</span>
        <input
          id="quote-phone"
          name="phone"
          type="tel"
          required
          placeholder={t('form.phone_placeholder')}
          class="w-full pl-12 pr-4 py-4 rounded-2xl bg-surface border border-outline-variant/30 focus:ring-2 focus:ring-primary/20 focus:border-primary/50 outline-none transition-all"
        />
      </div>
    </div>

    <button
      type="submit"
      class="w-full bg-secondary text-white font-bold py-5 rounded-2xl hover:bg-secondary/90 transition-all shadow-lg flex items-center justify-center gap-3 active:scale-95 group"
    >
      {t('form.quote_submit')}
      <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" aria-hidden="true">send</span>
    </button>

    <p class="text-center text-[10px] text-on-surface-variant pt-2 flex items-center justify-center gap-1">
      <span class="material-symbols-outlined text-[10px] text-secondary" aria-hidden="true">verified_user</span>
      {t('form.response_time')}
    </p>
  </form>

  <!-- Mensajes de estado -->
  <div id="quote-success" class="hidden mt-6 p-4 bg-secondary/10 border border-secondary/30 rounded-2xl text-center">
    <span class="material-symbols-outlined text-secondary text-3xl mb-2 block" aria-hidden="true">check_circle</span>
    <p class="font-bold text-on-surface">{t('form.success')}</p>
  </div>
  <div id="quote-error" class="hidden mt-6 p-4 bg-error/10 border border-error/30 rounded-2xl text-center">
    <span class="material-symbols-outlined text-error text-3xl mb-2 block" aria-hidden="true">error</span>
    <p class="font-bold text-on-surface">{t('form.error')}</p>
  </div>
</div>

<script>
  (function() {
    var form = document.getElementById('quote-form')
    if (!form) return

    var successEl = document.getElementById('quote-success')
    var errorEl   = document.getElementById('quote-error')
    var submitBtn = form.querySelector('button[type="submit"]')
    var btnText   = submitBtn ? submitBtn.textContent : ''

    form.addEventListener('submit', async function(e) {
      e.preventDefault()

      var fd = new FormData(form)

      var nombre = fd.get('name')
      var empresa = fd.get('company')
      var sector = fd.get('sector')
      var desafio = fd.get('challenge')
      var correo = fd.get('email')
      var telefono = fd.get('phone')

      var body = {
        nombre_completo:   nombre   ? String(nombre).trim()   : '',
        empresa:           empresa  ? String(empresa).trim()  : '',
        sector:            sector   ? String(sector).trim()   : '',
        desafio_ambiental: desafio  ? String(desafio).trim()  : '',
        correo:            correo   ? String(correo).trim()   : '',
        telefono:          telefono ? String(telefono).trim() : '',
      }

      var apiUrl = import.meta.env.PUBLIC_API_URL
      if (!apiUrl) {
        console.warn('PUBLIC_API_URL no configurada')
        form.classList.add('hidden')
        if (errorEl) errorEl.classList.remove('hidden')
        return
      }

      if (submitBtn) {
        submitBtn.disabled = true
        submitBtn.textContent = 'Enviando...'
      }

      try {
        var res = await fetch(apiUrl + '/leads-contacto', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        })

        if (res.ok) {
          form.classList.add('hidden')
          if (successEl) successEl.classList.remove('hidden')
          if (errorEl) errorEl.classList.add('hidden')
        } else {
          form.classList.add('hidden')
          if (errorEl) errorEl.classList.remove('hidden')
          if (successEl) successEl.classList.add('hidden')
        }
      } catch (_) {
        form.classList.add('hidden')
        if (errorEl) errorEl.classList.remove('hidden')
        if (successEl) successEl.classList.add('hidden')
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false
          submitBtn.textContent = btnText
        }
      }
    })
  })()
</script>
