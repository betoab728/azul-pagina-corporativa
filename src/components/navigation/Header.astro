---
import NavDropdown from './NavDropdown.astro'
import LanguageSelector from './LanguageSelector.astro'
import type { SupportedLocale } from '../../i18n/utils'
import { useTranslations } from '../../i18n/utils'
import { getMainNav } from '../../data/navigation'

interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const mainNav = getMainNav(lang)

const logoUrl = '/logoazul.png'

const homeItem     = mainNav.find(item => item.key === 'home')
const homeHref     = homeItem?.href ?? '/'
const serviceItem  = mainNav.find(item => item.key === 'services')
const serviceLinks = serviceItem?.dropdown ?? []
const recursosItem  = mainNav.find(item => item.key === 'resources')
const recursosLinks = recursosItem?.dropdown ?? []
const flatNavItems = mainNav.filter(item => item.key !== 'services' && item.key !== 'resources' && item.key !== 'home')
---

<header class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-outline-variant/30 py-2">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop flex justify-between items-center h-20">

    <!-- Logo -->
    <a href={homeHref} aria-label={t('aria.logo')} class="mr-4">
      <img
        src={logoUrl}
        alt="Azul Sostenible"
        class="h-10 w-auto"
        width="100"
        height="40"
        loading="eager"
      />
    </a>

    <!-- Navegación desktop -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Navegación principal">
      <a href={homeHref} class="text-on-surface-variant font-semibold hover:text-primary transition-colors text-sm">
        {t('nav.home')}
      </a>
      <NavDropdown label={t('nav.services')} items={serviceLinks} />
      {flatNavItems.map(item => (
        <a
          href={item.href}
          class="text-on-surface-variant font-semibold hover:text-primary transition-colors text-sm"
        >
          {item.label}
        </a>
      ))}
      <NavDropdown label={t('nav.resources')} items={recursosLinks} href="/recursos" />
    </nav>

    <!-- CTAs -->
    <div class="flex items-center gap-4">
      <LanguageSelector lang={lang} />

      <a
        href="#cotizacion"
        class="hidden md:flex items-center gap-2 bg-primary-container text-white font-bold px-6 py-3 rounded-full hover:bg-primary transition-all shadow-md active:scale-95 text-sm"
      >
        <span class="material-symbols-outlined text-base" aria-hidden="true">rocket_launch</span>
        {t('nav.cta')}
      </a>

      <!-- WhatsApp -->
      <a
        href="https://wa.me/51936602578"
        class="w-12 h-12 bg-[#25d366] text-white rounded-full flex items-center justify-center hover:bg-[#128c7e] transition-colors shadow-md"
        aria-label={t('aria.whatsapp')}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766 0-3.18-2.587-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.538-2.961-2.654-.087-.116-.708-.941-.708-1.794 0-.852.446-1.273.605-1.446.159-.173.346-.217.462-.217s.231.001.332.005c.109.004.253-.041.397.303.144.344.491 1.199.534 1.285.044.087.072.188.014.303-.058.116-.087.188-.173.289l-.26.303c-.087.101-.177.211-.076.386.101.174.45.743.966 1.204.665.594 1.225.779 1.4.865.174.086.274.072.376-.044.101-.116.433-.505.548-.679.116-.174.231-.144.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zM12 2C6.477 2 2 6.477 2 12c0 1.891.524 3.662 1.435 5.176L2 22l4.957-1.3c1.465.849 3.167 1.3 5.043 1.3 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
        </svg>
      </a>

      <!-- Botón menú móvil -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-on-surface rounded-lg hover:bg-surface-container transition-colors"
        aria-label={t('aria.open_menu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="material-symbols-outlined" aria-hidden="true">menu</span>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 top-0 bg-white z-[100] flex-col p-6 gap-1 overflow-y-auto shadow-2xl"
    style="display:none"
    role="dialog"
    aria-modal="true"
    aria-label={t('aria.main_nav')}
  >
    <a href={homeHref} class="text-on-surface font-semibold py-3 border-b border-outline-variant/20 hover:text-primary">
      {t('nav.home')}
    </a>

    <div class="py-2 border-b border-outline-variant/20">
      <p class="text-on-surface font-semibold py-2">{t('nav.services')}</p>
      {serviceLinks.map(item => (
        <a
          href={item.href}
          class="block text-on-surface-variant text-sm py-2 pl-4 hover:text-primary transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>

    {flatNavItems.map(item => (
      <a
        href={item.href}
        class="text-on-surface font-semibold py-3 border-b border-outline-variant/20 hover:text-primary transition-colors"
      >
        {item.label}
      </a>
    ))}

    <div class="py-2 border-b border-outline-variant/20">
      <p class="text-on-surface font-semibold py-2">{t('nav.resources')}</p>
      {recursosLinks.map(item => (
        <a
          href={item.href}
          class="block text-on-surface-variant text-sm py-2 pl-4 hover:text-primary transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>

    <LanguageSelector lang={lang} mobile />

    <a
      href="#cotizacion"
      class="mt-6 flex items-center justify-center gap-2 bg-secondary text-white font-bold px-6 py-4 rounded-full hover:bg-secondary/90 transition-all"
    >
      <span class="material-symbols-outlined" aria-hidden="true">rocket_launch</span>
      {t('nav.cta')}
    </a>
  </div>
</header>

<script is:inline>
  (function() {
    var btn  = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var icon = btn ? btn.querySelector('.material-symbols-outlined') : null;

    function setMenuTop() {
      var header = document.querySelector('header');
      if (menu && header) {
        var headerH = header.offsetHeight;
        menu.style.top = headerH + 'px';
        menu.style.height = 'calc(100vh - ' + headerH + 'px)';
      }
    }

    function openMenu() {
      if (!menu) return;
      setMenuTop();
      menu.style.display = 'flex';
      if (btn) btn.setAttribute('aria-expanded', 'true');
      if (icon) icon.textContent = 'close';
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      if (!menu) return;
      menu.style.display = 'none';
      if (btn) btn.setAttribute('aria-expanded', 'false');
      if (icon) icon.textContent = 'menu';
      document.body.style.overflow = '';
    }

    if (btn) {
      btn.addEventListener('click', function() {
        if (menu && menu.style.display === 'flex') {
          closeMenu();
        } else {
          openMenu();
        }
      });
    }

    if (menu) {
      var links = menu.querySelectorAll('a');
      for (var i = 0; i < links.length; i++) {
        links[i].addEventListener('click', closeMenu);
      }
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menu && menu.style.display === 'flex') {
        closeMenu();
      }
    });
  })();
</script>
