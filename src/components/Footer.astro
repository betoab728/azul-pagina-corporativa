---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const logoUrl = '/logoazul.png'
const currentYear = new Date().getFullYear()
const prefix = lang === 'es' ? '' : `/${lang}`

const footerServicesByLocale: Record<SupportedLocale, { label: string; href: string }[]> = {
  es: [
    { label: 'Caracterización de Residuos Sólidos', href: '/servicios/caracterizacion-de-residuos' },
    { label: 'Tarifa Plana', href: '/servicios/tarifa-plana' },
    { label: 'Reclasificación de Residuos Peligrosos', href: '/servicios/reclasificacion-de-residuos' },
    { label: 'Reducción del OPEX', href: '/servicios/reduccion-del-opex' },
    { label: 'Almacenes Inteligentes', href: '/servicios/almacenes-inteligentes' },
    { label: 'Software de Trazabilidad', href: '/servicios/software-trazabilidad' },
  ],
  en: [
    { label: 'Solid Waste Characterization', href: '/en/servicios/caracterizacion-de-residuos' },
    { label: 'Environmental Flat Rate', href: '/en/servicios/tarifa-plana' },
    { label: 'Hazardous Waste Reclassification', href: '/en/servicios/reclasificacion-de-residuos' },
    { label: 'OPEX Reduction', href: '/en/servicios/reduccion-del-opex' },
    { label: 'Smart Warehouses', href: '/en/servicios/almacenes-inteligentes' },
    { label: 'Traceability Software', href: '/en/servicios/software-trazabilidad' },
  ],
  pt: [
    { label: 'Caracterização de Resíduos Sólidos', href: '/pt/servicios/caracterizacion-de-residuos' },
    { label: 'Tarifa Fixa Ambiental', href: '/pt/servicios/tarifa-plana' },
    { label: 'Reclassificação de Resíduos Perigosos', href: '/pt/servicios/reclasificacion-de-residuos' },
    { label: 'Redução do OPEX', href: '/pt/servicios/reduccion-del-opex' },
    { label: 'Armazéns Inteligentes', href: '/pt/servicios/almacenes-inteligentes' },
    { label: 'Software de Rastreabilidade', href: '/pt/servicios/software-trazabilidade' },
  ],
}
const servicios = footerServicesByLocale[lang]

const legalLinks = [
  { label: t('footer.privacy'), href: `${prefix}/politica-de-privacidad` },
  { label: t('footer.terms'), href: `${prefix}/terminos-y-condiciones` },
  { label: t('footer.complaints'), href: `${prefix}/libro-de-reclamaciones` },
]
---

<footer class="bg-[#0a1628] text-white">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Columna 1: Empresa -->
      <div class="space-y-6">
        <a href={`${prefix}/`} aria-label={t('aria.logo')}>
          <img
            src={logoUrl}
            alt="Azul Sostenible"
            class="h-14 w-auto brightness-0 invert"
            width="140"
            height="56"
            loading="lazy"
          />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          {t('footer.tagline')}
        </p>
        <a
          href={`${prefix}/contacto`}
          class="inline-flex items-center gap-2 bg-secondary text-white font-bold px-6 py-3 rounded-full hover:bg-secondary/90 transition-colors text-sm"
        >
          {t('btn.request_quote')}
          <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span>
        </a>
      </div>

      <!-- Columna 2: Servicios -->
      <div>
        <h4 class="font-headline text-lg font-bold mb-6 text-white">{t('footer.services')}</h4>
        <nav aria-label="Servicios">
          <ul class="space-y-3">
            {servicios.map(servicio => (
              <li>
                <a
                  href={servicio.href}
                  class="text-gray-400 hover:text-secondary transition-colors text-sm"
                >
                  {servicio.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Columna 3: Contacto -->
      <div>
        <h4 class="font-headline text-lg font-bold mb-6 text-white">{t('footer.contact')}</h4>
        <address class="not-italic space-y-4">
          <div class="flex items-start gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0 mt-0.5" aria-hidden="true">location_on</span>
            <span>Av. Tallanes Condominio Garden 360,<br />Dpto 405 Torre 6<br />Piura - Piura</span>
          </div>
          <div class="flex items-center gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0" aria-hidden="true">call</span>
            <a href="tel:+51936602578" class="hover:text-secondary transition-colors">+51 936 602 578</a>
          </div>
          <div class="flex items-center gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0 opacity-0" aria-hidden="true">call</span>
            <a href="tel:+51940857666" class="hover:text-secondary transition-colors">+51 940 857 666</a>
          </div>
          <div class="flex items-center gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0 opacity-0" aria-hidden="true">call</span>
            <a href="tel:+51912780626" class="hover:text-secondary transition-colors">+51 912 780 626</a>
          </div>
          <div class="flex items-center gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0" aria-hidden="true">mail</span>
            <a href="mailto:azulsostenibleoficial@gmail.com" class="hover:text-secondary transition-colors">azulsostenibleoficial@gmail.com</a>
          </div>
          <div class="flex items-start gap-3 text-gray-400 text-sm">
            <span class="material-symbols-outlined text-secondary text-lg shrink-0 mt-0.5" aria-hidden="true">schedule</span>
            <span>{t('footer.schedule')}<br />{t('footer.hours')}</span>
          </div>
        </address>
      </div>

      <!-- Columna 4: Redes Sociales -->
      <div>
        <h4 class="font-headline text-lg font-bold mb-6 text-white">{t('footer.social')}</h4>
        <div class="flex flex-wrap gap-3 mb-6">
          <!-- Facebook -->
          <a href="https://web.facebook.com/people/Azul-Sostenible/100076063132375" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#1877F2] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <!-- Instagram -->
          <a href="https://www.instagram.com/azul.sostenible/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#E4405F] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/azulsostenible/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#0A66C2] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <!-- TikTok -->
          <a href="https://www.tiktok.com/@azulsostenible.peru" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#000000] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.73 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
          <!-- YouTube -->
          <a href="https://www.youtube.com/@azulsostenible" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#FF0000] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <!-- WhatsApp -->
          <a href="https://wa.me/51936602578" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#25D366] hover:scale-110 transition-all">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.438 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.705 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          {t('footer.follow')}
        </p>
      </div>

    </div>

    <!-- Separador + Copyright -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} Azul Sostenible. {t('footer.rights')}
      </p>
      <nav aria-label={t('aria.legal_nav')}>
        <ul class="flex flex-wrap gap-6 text-sm">
          {legalLinks.map(link => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-secondary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
