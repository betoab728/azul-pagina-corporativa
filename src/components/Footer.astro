---
const logoUrl = '/logoazul.png'

const currentYear = new Date().getFullYear()

const links = [
  { label: 'Privacidad', href: '#' },
  { label: 'Términos', href: '#' },
  { label: 'Soporte', href: '#' },
]
---

<footer class="bg-on-surface text-white py-12 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">

      <a href="/" aria-label="Azul Sostenible — Inicio">
        <img
          src={logoUrl}
          alt="Azul Sostenible"
          class="h-12 w-auto brightness-0 invert"
          width="120"
          height="48"
          loading="lazy"
        />
      </a>

      <nav aria-label="Navegación legal">
        <ul class="flex gap-8 text-sm font-semibold opacity-70">
          {links.map(link => (
            <li>
              <a href={link.href} class="hover:opacity-100 transition-opacity">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <p class="text-xs opacity-50">
        &copy; {currentYear} Azul Sostenible. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
