---
interface Props {
  text: string
  color?: 'secondary' | 'primary'
}

const { text, color = 'secondary' } = Astro.props

const colorClass = color === 'primary' ? 'text-primary' : 'text-secondary'
---

<span class={`${colorClass} font-bold text-sm uppercase tracking-widest mb-4 block`}>
  {text}
</span>
