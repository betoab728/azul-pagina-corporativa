---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low" aria-labelledby="carahuacra-faq-heading">
  <div class="max-w-3xl mx-auto px-6">
    <h2 id="carahuacra-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('about.faq')}</h2>
    <div class="space-y-4">
      <details class="group bg-surface-container-lowest rounded-2xl p-6 border border-outline-variant open:ring-2 open:ring-secondary transition-all">
        <summary class="flex justify-between items-center cursor-pointer list-none">
          <span class="font-headline text-2xl font-bold">{t('carahuacra.faq.q1')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <p class="mt-4 text-on-surface-variant">
          {t('carahuacra.faq.a1')}
        </p>
      </details>
      <details class="group bg-surface-container-lowest rounded-2xl p-6 border border-outline-variant open:ring-2 open:ring-secondary transition-all">
        <summary class="flex justify-between items-center cursor-pointer list-none">
          <span class="font-headline text-2xl font-bold">{t('carahuacra.faq.q2')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <p class="mt-4 text-on-surface-variant">
          {t('carahuacra.faq.a2')}
        </p>
      </details>
    </div>
  </div>
</section>
