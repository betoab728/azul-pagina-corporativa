---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import ServiceCard from '../components/blocks/ServiceCard.astro'
import { getServices } from '../data/services'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const services = getServices(lang)
---

<section id="servicios" class="py-20 bg-white" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold text-sm uppercase tracking-widest">{t('section.services')}</span>
      <h2 id="services-heading" class="font-headline text-4xl md:text-5xl font-extrabold mt-4 mb-4">
        {t('services.tagline')}
      </h2>
      <p class="text-on-surface-variant text-lg max-w-2xl mx-auto">
        {t('services.description')}
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-8">
      {services.map(service => (
        <div class="w-full md:w-[calc(33.333%-1.34rem)]">
          <ServiceCard {...service} cta={t('btn.view_more')} />
        </div>
      ))}
    </div>
  </div>
</section>