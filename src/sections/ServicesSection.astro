---
import ServiceCard from '../components/blocks/ServiceCard.astro'
import { services } from '../data/services'
---

<section id="servicios" class="py-20 bg-white" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold text-sm uppercase tracking-widest">NUESTROS SERVICIOS</span>
      <h2 id="services-heading" class="font-headline text-4xl md:text-5xl font-extrabold mt-4 mb-4">
        Soluciones integrales para <span class="text-secondary">cada</span> necesidad
      </h2>
      <p class="text-on-surface-variant text-lg max-w-2xl mx-auto">
        Diseñamos e implementamos soluciones ambientales efectivas y sostenibles.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map(service => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>
