---
import { serviceCards } from '../data/nosotros'
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="nosotros-servicios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop text-center mb-8 md:mb-16">
    <h2 id="nosotros-servicios-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-6">¿Qué servicios de gestión de residuos ofrece Azul Sostenible?</h2>
    <p class="text-lg text-on-surface-variant max-w-4xl mx-auto">
      Azul Sostenible brinda servicios de gestión de residuos sólidos, peligrosos e industriales que incluyen caracterización, recolección, transporte autorizado, valorización y disposición final, conforme a la normativa ambiental vigente en Perú.
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-8">
    {serviceCards.map(card => (
      <div class="bg-surface p-6 md:p-10 rounded-xl border border-outline-variant shadow-sm hover:border-secondary transition-all text-center">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-6 mx-auto">
          <span class="material-symbols-outlined text-primary text-[32px]" aria-hidden="true">{card.icon}</span>
        </div>
        <h3 class="font-headline text-2xl font-bold text-primary">{card.title}</h3>
      </div>
    ))}
  </div>
</section>
