---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding bg-primary relative overflow-hidden" aria-labelledby="acreditaciones-cta-heading">
  <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop text-center relative z-10">
    <h2 id="acreditaciones-cta-heading" class="font-headline text-[32px] md:text-5xl text-white font-extrabold mb-12 uppercase leading-tight">
      {t('acreditaciones.cierre.title_1')}<br />{t('acreditaciones.cierre.title_2')}
    </h2>
    <div class="flex justify-center">
      <a
        href="https://wa.me/51936602578"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-secondary text-white font-bold px-6 md:px-12 py-3 md:py-5 rounded-full hover:scale-105 transition-transform shadow-lg"
      >
        {t('acreditaciones.cierre.cta')}
        <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
