---
import type { SupportedLocale } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBGMDfR3WBJPnhKL6rB-5qtmAzA3JZbQ7jrPizFKF_GA1Q9dqYn7Q2fvoEOKfFIs7RiUrjTS7CHs6kRHNbpX4vziIyrDA05aMXW_7QOdZRUUALQJmDqt76dk4PnoQzzaWdVtENb5xWyPFb0YkguvIlstqud4BS4rdRMQdOg-D9nYpAEHcijp_6x2o7ie9CUhPC3tfoxeY2fyBMkxHPcIfTBiX9XF8AzqwSPO_96AqVlOicBLWTAMUcxPz_rRtot69fd8Y8_KLRXhgOS'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---

<section id="iscaycruz-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="iscaycruz-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 bg-primary/40" style="mix-blend-mode: multiply;"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full text-white">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 px-4 py-1 mb-6 rounded-full bg-secondary/90 backdrop-blur-sm text-white text-sm font-bold uppercase tracking-wider">
        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">verified</span>
        Casos de Éxito
      </span>
      <h1 id="iscaycruz-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight font-extrabold mb-4">UM. ISCAYCRUZ: Ingeniería para la Sostenibilidad Minera</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed max-w-xl">Evaluación técnica especializada para la reclasificación de residuos y optimización de procesos industriales.</p>
    </div>
  </div>
</section>