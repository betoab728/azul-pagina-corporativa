---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding bg-primary relative overflow-hidden" aria-labelledby="proyectos-cta-heading">
  <div class="absolute top-0 right-0 w-1/2 h-full bg-secondary/10 skew-x-12 translate-x-1/4 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop text-center">
    <h2 id="proyectos-cta-heading" class="font-headline text-[32px] md:text-5xl text-white font-extrabold mb-6">{t('proyectos.cierre.title')}</h2>
    <p class="text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
      {t('proyectos.cierre.body')}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://wa.me/51936602578"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center bg-secondary text-white font-bold px-6 md:px-8 py-3 md:py-4 rounded-full hover:bg-secondary-fixed hover:text-on-secondary-fixed transition-colors shadow-lg"
      >
        {t('proyectos.cierre.cta')}
      </a>
    </div>
  </div>
</section>
