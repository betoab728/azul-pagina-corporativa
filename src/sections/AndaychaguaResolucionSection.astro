---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low" aria-labelledby="andaychagua-resolucion-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 bg-white rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-primary mb-3" aria-hidden="true">fact_check</span>
            <h5 class="font-bold text-sm text-primary">{t('andaychagua.resolucion.step_docs')}</h5>
          </div>
          <div class="p-6 bg-white rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-primary mb-3" aria-hidden="true">visibility</span>
            <h5 class="font-bold text-sm text-primary">{t('andaychagua.resolucion.step_visual')}</h5>
          </div>
          <div class="p-6 bg-white rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-primary mb-3" aria-hidden="true">biotech</span>
            <h5 class="font-bold text-sm text-primary">{t('andaychagua.resolucion.step_lab')}</h5>
          </div>
          <div class="p-6 bg-white rounded-xl shadow-sm border border-outline-variant">
            <span class="material-symbols-outlined text-primary mb-3" aria-hidden="true">rule</span>
            <h5 class="font-bold text-sm text-primary">{t('andaychagua.resolucion.step_physical')}</h5>
          </div>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <h2 id="andaychagua-resolucion-heading" class="font-headline text-4xl font-extrabold text-primary mb-6">{t('andaychagua.resolucion.title')}</h2>
        <p class="text-on-surface-variant mb-6 leading-relaxed">
          {t('andaychagua.resolucion.body')}
        </p>
        <div class="p-6 bg-primary text-white rounded-xl">
          <p class="italic">
            {t('andaychagua.resolucion.quote')}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
