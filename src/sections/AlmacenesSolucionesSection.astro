---
import { bentoItems } from '../data/almacenes-inteligentes'

// TODO: Reemplazar con imagen real del cliente
const bentoImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuAJRsp16KIzwB0IhOoNepTbacB9wSa-p5bO21RjbLbvmkEnzPkPMFaxlIU_C0Rz_bJGhcopa3Ea0THYTkGzBeM03n5ZQmjOLL2FSDY_3zkTCuA1nXA0TyiPNrC0-Syauu80Z8Uh59VSL_2_kh2nz6RXhZHYTTRUcyj59e7BeztcfeP5NKMzn8nIwBQpNQELoSlaatw7usyYES6VE3vIPw6rGooCSz2O8rz9RahOel6HyhcdG2Zerd6xBUHILubNIq2N8_oBjlCgzFt9'
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="almacenes-soluciones-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16 space-y-4">
      <h2 id="almacenes-soluciones-heading" class="font-headline text-4xl md:text-5xl font-extrabold">Soluciones Técnicas de <span class="text-primary">Ingeniería</span></h2>
      <p class="text-on-surface-variant max-w-2xl mx-auto">Aplicamos metodologías de clase mundial para redefinir su infraestructura de gestión de materiales.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {bentoItems.map(item => (
        item.variant === 'large' ? (
          <article class="md:col-span-2 bg-white p-6 md:p-10 rounded-xl border border-outline-variant flex flex-col justify-between group hover:shadow-2xl transition-all duration-500">
            <div>
              <div class="w-14 h-14 bg-primary-container text-on-primary-container rounded-lg flex items-center justify-center mb-6">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{item.icon}</span>
              </div>
              <h3 class="text-2xl font-bold mb-4">{item.title}</h3>
              <p class="text-on-surface-variant max-w-md">{item.description}</p>
            </div>
            <div class="mt-8 overflow-hidden rounded-lg h-48 bg-surface-container relative">
              <img
                src={bentoImage}
                alt="Plano industrial con diseño de almacén optimizado"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                width="600"
                height="192"
              />
            </div>
          </article>
        ) : item.variant === 'dark' ? (
          <article class="bg-primary text-white p-6 md:p-10 rounded-xl flex flex-col justify-between group">
            <div class="space-y-6">
              <span class="material-symbols-outlined text-4xl text-secondary-fixed" aria-hidden="true">{item.icon}</span>
              <h3 class="text-2xl font-bold">{item.title}</h3>
              <p class="text-white/80">{item.description}</p>
              <ul class="space-y-3">
                <li class="flex items-center gap-2 text-sm"><span class="material-symbols-outlined text-xs" aria-hidden="true">check_circle</span> Segregación técnica</li>
                <li class="flex items-center gap-2 text-sm"><span class="material-symbols-outlined text-xs" aria-hidden="true">check_circle</span> Control de derrames</li>
                <li class="flex items-center gap-2 text-sm"><span class="material-symbols-outlined text-xs" aria-hidden="true">check_circle</span> Ventilación forzada</li>
              </ul>
            </div>
            <a href="#cotizacion" class="mt-8 text-secondary-fixed font-bold flex items-center gap-2 group-hover:gap-4 transition-all">
              Saber más
              <span class="material-symbols-outlined" aria-hidden="true">east</span>
            </a>
          </article>
        ) : (
          <article class="bg-white p-8 rounded-xl border border-outline-variant flex flex-col gap-4">
            <span class={`material-symbols-outlined text-3xl ${item.iconStyle === 'secondary' ? 'text-secondary' : 'text-primary'}`} aria-hidden="true">{item.icon}</span>
            <h3 class="font-bold text-xl">{item.title}</h3>
            <p class="text-on-surface-variant text-sm">{item.description}</p>
          </article>
        )
      ))}
    </div>
  </div>
</section>
