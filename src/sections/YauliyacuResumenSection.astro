---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="yauliyacu-resumen-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="yauliyacu-resumen-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('yauliyacu.resumen.title')}</h2>
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-8 p-8 bg-primary text-white rounded-3xl flex flex-col justify-between shadow-2xl relative overflow-hidden">
        <div class="relative z-10">
          <h3 class="font-headline text-2xl font-bold mb-4">{t('yauliyacu.resumen.card1_title')}</h3>
          <p class="text-lg text-white/80 max-w-xl">{t('yauliyacu.resumen.card1_desc')}</p>
        </div>
        <div class="mt-12 flex items-baseline gap-2">
          <span class="text-[64px] font-extrabold leading-none">100%</span>
          <span class="font-headline text-2xl font-bold">{t('yauliyacu.resumen.metric1_label')}</span>
        </div>
        <div class="absolute -right-16 -bottom-16 w-64 h-64 bg-white/10 rounded-full blur-3xl" aria-hidden="true"></div>
      </div>
      <div class="col-span-12 md:col-span-4 p-8 bg-surface-container-high border border-outline-variant rounded-3xl flex flex-col justify-center gap-6">
        <div class="w-14 h-14 rounded-2xl bg-secondary-container text-on-secondary-container flex items-center justify-center">
          <span class="material-symbols-outlined text-[32px]" aria-hidden="true">trending_up</span>
        </div>
        <div>
          <h3 class="font-headline text-xl font-bold mb-2">{t('yauliyacu.resumen.card2_title')}</h3>
          <p class="text-on-surface-variant">{t('yauliyacu.resumen.card2_desc')}</p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-12 p-12 bg-white border border-outline-variant rounded-3xl flex flex-col md:flex-row items-center gap-12 shadow-sm">
        <div class="flex-1">
          <h3 class="font-headline text-2xl font-bold text-primary mb-4">{t('yauliyacu.resumen.card3_title')}</h3>
          <p class="text-on-surface-variant">{t('yauliyacu.resumen.card3_desc')}</p>
        </div>
        <div class="shrink-0 flex gap-4">
          <div class="p-6 text-center border border-outline-variant rounded-2xl">
            <p class="font-headline text-2xl font-bold text-primary">85%</p>
            <p class="text-sm font-bold text-on-surface-variant/60">{t('yauliyacu.resumen.stat1_label')}</p>
          </div>
          <div class="p-6 text-center border border-outline-variant rounded-2xl bg-surface-container-low">
            <p class="font-headline text-2xl font-bold text-secondary">Eco</p>
            <p class="text-sm font-bold text-on-surface-variant/60">{t('yauliyacu.resumen.stat2_label')}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
