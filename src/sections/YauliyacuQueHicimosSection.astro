---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="yauliyacu-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-16 items-start">
      <div class="w-full md:w-1/2">
        <span class="text-primary font-bold text-sm tracking-wider uppercase mb-4 block">{t('yauliyacu.que_hicimos.phase_label')}</span>
        <h2 id="yauliyacu-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('yauliyacu.que_hicimos.title')}</h2>
        <div class="space-y-6">
          <div class="flex gap-4 p-6 rounded-xl bg-surface-container-low border border-outline-variant hover:border-primary transition-all duration-300">
            <div class="w-12 h-12 shrink-0 bg-primary-container text-white rounded-lg flex items-center justify-center">
              <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{t('yauliyacu.que_hicimos.step1_title')}</h3>
              <p class="text-on-surface-variant">{t('yauliyacu.que_hicimos.step1_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4 p-6 rounded-xl bg-surface-container-low border border-outline-variant hover:border-primary transition-all duration-300">
            <div class="w-12 h-12 shrink-0 bg-secondary-container text-on-secondary-container rounded-lg flex items-center justify-center">
              <span class="material-symbols-outlined" aria-hidden="true">sanitizer</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{t('yauliyacu.que_hicimos.step2_title')}</h3>
              <p class="text-on-surface-variant">{t('yauliyacu.que_hicimos.step2_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4 p-6 rounded-xl bg-surface-container-low border border-outline-variant hover:border-primary transition-all duration-300">
            <div class="w-12 h-12 shrink-0 bg-tertiary-container text-on-tertiary-container rounded-lg flex items-center justify-center">
              <span class="material-symbols-outlined" aria-hidden="true">biotech</span>
            </div>
            <div>
              <h3 class="font-headline text-xl font-bold mb-2">{t('yauliyacu.que_hicimos.step3_title')}</h3>
              <p class="text-on-surface-variant">{t('yauliyacu.que_hicimos.step3_desc')}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="w-full md:w-1/2 md:sticky md:top-32">
        <div class="relative group">
          <div class="absolute -inset-4 bg-primary/10 rounded-2xl blur-lg group-hover:bg-primary/20 transition-all"></div>
          <div class="relative overflow-hidden rounded-xl border border-outline-variant shadow-lg">
            <img
              alt={t('yauliyacu.que_hicimos.img_alt')}
              class="w-full aspect-video object-cover"
              src="/yauliyacui-hicimos.jpeg"
              loading="lazy"
              width="600"
              height="337"
            />
            <div class="p-6 bg-white border-t border-outline-variant">
              <p class="font-bold text-sm text-primary mb-1">{t('yauliyacu.que_hicimos.ref_label')}</p>
              <p class="text-on-surface-variant italic">{t('yauliyacu.que_hicimos.quote')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
