---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="morococha-faq-heading">
  <div class="max-w-[800px] mx-auto px-6">
    <h2 id="morococha-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('about.faq')}</h2>
    <div class="space-y-6">
      <details class="group border border-outline-variant rounded-xl overflow-hidden hover:border-primary transition-all bg-white">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('morococha.faq.q1')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="p-6 pt-0 text-on-surface-variant border-t border-outline-variant pt-6">
          {t('morococha.faq.a1')}
        </div>
      </details>
      <details class="group border border-outline-variant rounded-xl overflow-hidden hover:border-primary transition-all bg-white">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('morococha.faq.q2')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="p-6 pt-0 text-on-surface-variant border-t border-outline-variant pt-6">
          {t('morococha.faq.a2')}
        </div>
      </details>
      <details class="group border border-outline-variant rounded-xl overflow-hidden hover:border-primary transition-all bg-white">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('morococha.faq.q3')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="p-6 pt-0 text-on-surface-variant border-t border-outline-variant pt-6">
          {t('morococha.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
