---
import type { SupportedLocale } from '../i18n/utils'
import { getEventos } from '../data/recursos'

const eventBgClasses: Record<string, string> = {
  primary: 'bg-primary text-white',
  secondary: 'bg-secondary text-white',
  tertiary: 'bg-tertiary text-white',
}
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const eventos = getEventos(lang)
---

<section class="py-section-padding" aria-labelledby="recursos-capacitaciones-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-6 items-center">

      <div class="md:w-1/3">
        <h2 id="recursos-capacitaciones-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold mb-6">Calendario de Capacitaciones</h2>
        <p class="text-on-surface-variant mb-8">Participa en nuestras sesiones de formación técnica dictadas por especialistas con amplia trayectoria en el sector ambiental.</p>
        <div class="space-y-4">
          <div class="flex items-center gap-4 text-on-surface">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">verified</span>
            <span class="text-sm font-bold">Certificación oficial incluida</span>
          </div>
          <div class="flex items-center gap-4 text-on-surface">
            <span class="material-symbols-outlined text-primary" aria-hidden="true">videocam</span>
            <span class="text-sm font-bold">Modalidades Presencial y Online</span>
          </div>
        </div>
      </div>

      <div class="md:w-2/3 w-full">
        <div class="bg-white border border-outline-variant rounded-xl divide-y divide-outline-variant overflow-hidden shadow-sm">
          {eventos.map(evento => (
            <div class="p-6 flex flex-col sm:flex-row items-center gap-6 hover:bg-surface-container-low transition-colors cursor-pointer">
              <div class={`flex flex-col items-center justify-center min-w-[80px] h-20 rounded-lg shrink-0 ${eventBgClasses[evento.bgColor]}`}>
                <span class="text-xl font-bold">{evento.day}</span>
                <span class="text-xs uppercase">{evento.month}</span>
              </div>
              <div class="flex-grow text-center sm:text-left">
                <h4 class="font-headline text-2xl font-bold text-on-surface mb-1">{evento.title}</h4>
                <p class="text-on-surface-variant text-sm">{evento.description}</p>
              </div>
              <a href={evento.pdfUrl} target="_blank" rel="noopener noreferrer" class="inline-flex bg-surface-container-highest font-bold px-6 py-2 rounded-full text-sm hover:bg-primary hover:text-white transition-all shrink-0">Ver más</a>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>