---
import type { SupportedLocale } from '../i18n/utils'
import { getPilares } from '../data/tarifa-plana'

const iconContainerClasses: Record<string, string> = {
  'secondary-container': 'bg-secondary-container text-on-secondary-container',
  'primary-container': 'bg-primary-container text-on-primary-container',
  'tertiary-container': 'bg-tertiary-container text-on-tertiary-container',
}
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const pilares = getPilares(lang)
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="tarifa-plana-incluye-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16">
      <h2 id="tarifa-plana-incluye-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">¿QUÉ INCLUYE?</h2>
      <p class="text-lg text-on-surface-variant max-w-2xl mx-auto">Tres pilares fundamentales que sostienen la operatividad y legalidad de su organización.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {pilares.map(pilar => (
        <article class="group bg-surface p-6 md:p-10 rounded-2xl border border-outline-variant hover:border-secondary transition-all hover:shadow-xl duration-500">
          <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform ${iconContainerClasses[pilar.iconColor]}`}>
            <span class="material-symbols-outlined text-[32px]" aria-hidden="true">{pilar.icon}</span>
          </div>
          <h3 class="font-headline text-2xl font-bold text-primary mb-4">{pilar.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{pilar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>