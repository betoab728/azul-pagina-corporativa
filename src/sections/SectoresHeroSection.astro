---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
// TODO: Reemplazar con imagen real del cliente
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDZsDiyWIWufYKrvo4SUQUaqUxChQ-acE_OSKJuJjTEeoGdEOUgxZOVcsK2ExKGy2szt7aVhpXBS-wVofVqE77Q3rNGQXsEyQ54Ko7LJu9y_mfddvP0PC37LV4PrM9B_Q2ixL54rEHECb-NkT2Aeu83rCM6mS7oDglypkPLjccijE2ME1ZAScT5dbeDfxaVLN1f6t-7A7JEe5GCCoVCdNW8Jy9eNWpIXVoHodiCKSR9vrt9To6OJKenLzFn_vUJL6G8ilssP_B9cWLd'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="sectores-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="sectores-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 opacity-80" style="background: linear-gradient(135deg, rgba(0, 71, 145, 0.9) 0%, rgba(0, 110, 7, 0.7) 100%);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">{t('sectores.hero.badge')}</span>
      <h1 id="sectores-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-4">{t('sectores.hero.title')}</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed mb-10">{t('sectores.hero.subtitle')}</p>
      <div class="flex gap-4">
        <a
          href="#sectores-bento"
          class="inline-flex items-center gap-2 bg-secondary text-white font-bold px-6 md:px-8 py-3 md:py-4 rounded-full hover:translate-y-[-2px] transition-transform shadow-lg"
        >
          {t('sectores.hero.cta')}
          <span class="material-symbols-outlined" aria-hidden="true">arrow_downward</span>
        </a>
      </div>
    </div>
  </div>
</section>