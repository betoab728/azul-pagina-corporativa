---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBe8oe1EPRgU8XZn1wv8Tzo3gfgMID5RW1z28pWNnePk0t22x7fE8KI2wfminuNt7lNSM9-_igYTF-q-HzPELm2FE0Wr3NyIBSXSKfJLAoZdqUKSOqJ3kWctNUv8UBZAoqbX9bdVIYmF-NBappCwYbdKCLnDBC2qTNbnu9QQMS0V9RIe5Uk5Acx9Bc2MbQaBsFyNSZXdPOcd4o2pdJ9dyBQI0ZoS_aLYSAj8rfMzAYSoMIVQ0TFyBUsqF3mwKCjaQFs9rlaL1OvzWzz'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="cristobal-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="cristobal-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full text-white">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">
        {t('projects.badge')}
      </span>
      <h1 id="cristobal-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight font-extrabold mb-6">U.M. SAN CRISTÓBAL</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed mb-8">
        {t('cristobal.hero.subtitle')}
      </p>
      <div class="flex flex-wrap gap-4 text-sm font-bold">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary-container" aria-hidden="true">verified</span>
          {t('cristobal.hero.tag_compliance')}
        </span>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-secondary-container" aria-hidden="true">analytics</span>
          {t('cristobal.hero.tag_reclassification')}
        </span>
      </div>
    </div>
  </div>
</section>