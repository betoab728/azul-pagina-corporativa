---
import type { SupportedLocale } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---
<section class="py-section-padding" aria-labelledby="sectores-cta-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-primary rounded-3xl p-12 md:p-20 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
      </div>

      <div class="relative z-10">
        <h2 id="sectores-cta-heading" class="font-headline text-[32px] md:text-5xl text-white font-extrabold mb-6">¿Listo para elevar sus estándares ambientales?</h2>
        <p class="text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">Agende una consultoría técnica con nuestros especialistas y descubra cómo podemos optimizar su gestión sectorial.</p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center bg-secondary text-white font-bold px-6 md:px-10 py-3 md:py-4 rounded-full hover:scale-105 transition-all"
          >
            Solicitar Auditoría
          </a>
          <a
            href="https://wa.me/51940857666"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center border border-white/30 text-white font-bold px-6 md:px-10 py-3 md:py-4 rounded-full hover:bg-white/10 transition-all"
          >
            Hablar con un Experto
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
