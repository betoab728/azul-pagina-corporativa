---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getPartners } from '../data/partners'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const partners = getPartners(lang)
---

<section class="py-20 bg-white" aria-label="Empresas que confían en Azul Sostenible">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-12">
      <p class="text-primary font-bold text-xl mb-8">
        {t('partners.tagline')}
      </p>

      <div id="partners-container" class="relative bg-white shadow-xl rounded-2xl p-10 border border-outline-variant/20 overflow-hidden">
        <div id="partners-track" class="flex items-center gap-16">
          {partners.map(partner => (
            <div class="flex-shrink-0">
              <img
                src={partner.logo}
                alt={`Logo de ${partner.name}`}
                class="h-20 w-auto max-w-none object-contain"
                width="120"
                height="56"
              />
            </div>
          ))}
          {partners.map(partner => (
            <div class="flex-shrink-0">
              <img
                src={partner.logo}
                alt={`Logo de ${partner.name}`}
                class="h-20 w-auto max-w-none object-contain"
                width="120"
                height="56"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('partners-track')
  const container = document.getElementById('partners-container')

  if (track && container) {
    let position = 0
    const speed = 1.5
    let paused = false
    let halfWidth = 0

    function updateHalfWidth() {
      halfWidth = track.scrollWidth / 2
    }

    function animate() {
      if (!paused) {
        position -= speed
        if (position <= -halfWidth) {
          position += halfWidth
        }
        track.style.transform = `translateX(${position}px)`
      }
      requestAnimationFrame(animate)
    }

    updateHalfWidth()
    window.addEventListener('resize', updateHalfWidth)

    container.addEventListener('mouseenter', () => { paused = true })
    container.addEventListener('mouseleave', () => { paused = false })

    requestAnimationFrame(animate)
  }
</script>