---
import { partners } from '../data/partners'
---

<section class="py-20 bg-white" aria-label="Empresas que confían en Azul Sostenible">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-12">
      <p class="text-primary font-bold text-sm mb-8">
        Cada empresa que ves aquí confió su gestión ambiental a nuestras manos
      </p>

      <div class="relative bg-white shadow-xl rounded-2xl p-8 border border-outline-variant/20 overflow-hidden">
        <!-- Logos con animación de desplazamiento -->
        <div class="partners-track flex items-center gap-12">
          {partners.map(partner => (
            <div class="flex-shrink-0">
              <img
                src={partner.logo}
                alt={`Logo de ${partner.name}`}
                class="h-14 w-auto max-w-none object-contain transition-all duration-500"
                loading="lazy"
                width="120"
                height="56"
              />
            </div>
          ))}
          <!-- Duplicado para scroll infinito sin corte -->
          {partners.map(partner => (
            <div class="flex-shrink-0">
              <img
                src={partner.logo}
                alt={`Logo de ${partner.name}`}
                class="h-14 w-auto max-w-none object-contain transition-all duration-500"
                loading="lazy"
                width="120"
                height="56"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .partners-track {
    animation: scroll 40s linear infinite;
  }

  .partners-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
