---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida/AP1WRLtsK2q_V_Xqmei93rVPGR0CqYiHQ8957IpG8nrVoRun6z0OPp37YMjpkkcqOgsRCNHVmxZm9gYR7K4V0aVgb663hpdUiE5xwMtWuAG5XAF66SDhreNPxOdGkb3flBkVKKmdcrxoOtzKYPv8VPiZR11vekNaMLqGEXxiMXg614g13NNHmSM1CdO9ewbudxuyGbQpjjjajZgvQtsFaj0mmi8SenFhOQWDvfMrpeqxqy_ss68Y_jYLdR0izGHl'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="yauliyacu-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="yauliyacu-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 opacity-80" style="background: linear-gradient(135deg, rgba(0, 71, 145, 0.9) 0%, rgba(0, 110, 7, 0.7) 100%);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">
        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">verified</span>
        {t('projects.badge')}
      </span>
      <h1 id="yauliyacu-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-4">{t('yauliyacu.hero.title')}</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed">{t('yauliyacu.hero.subtitle')}</p>
    </div>
  </div>
</section>
