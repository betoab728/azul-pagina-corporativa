---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getAgroStats } from '../data/sectores'
const agroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuAOt0XOReFgdNPTLTupxxFSvmzHlnwEtf21uIur9I8flNB_M4uTnGw7vHK8Ilo1zbY2lqwsmVLxpxJrdD4OytcjpuPoPsYWLUf7CrZ85nZAEr6goTvscceVzL7DY0KYwD0tFUAiFiJ_tygsSxAHCYI8N85qlm6kWEeEKDeS8xX2bfxFYvR9ba3VfTvzW77f2i651zVpuvnwuOcMqGxBCL6g-awoGuYs9pGnYEDVDWKx3T-lszCKdzSt5kCDG75O3Q1eKBJv_mh2chM0'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const agroStats = getAgroStats(lang)
---

<section id="sectores-bento" class="py-section-padding" aria-labelledby="sectores-bento-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16">
      <h2 id="sectores-bento-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">{t('sectores.bento.title')}</h2>
      <div class="w-20 h-1 bg-secondary mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:auto-rows-[320px]">

      <!-- Sector Industrial -->
      <article class="md:col-span-8 bg-surface-container-lowest rounded-xl border border-outline-variant p-8 flex flex-col justify-between relative overflow-hidden group hover:-translate-y-2 transition-transform duration-300">
        <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity pointer-events-none" aria-hidden="true">
          <span class="material-symbols-outlined text-[120px]">factory</span>
        </div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-primary text-3xl" aria-hidden="true">precision_manufacturing</span>
            <h3 class="font-headline text-2xl font-bold text-primary">{t('sectores.bento.industrial.title')}</h3>
          </div>
          <p class="text-on-surface-variant max-w-md mb-6">{t('sectores.bento.industrial.body')}</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-4">
            <li class="flex items-center gap-2 text-sm font-bold text-on-surface"><span class="material-symbols-outlined text-secondary text-sm" aria-hidden="true">check_circle</span> {t('sectores.bento.industrial.li1')}</li>
            <li class="flex items-center gap-2 text-sm font-bold text-on-surface"><span class="material-symbols-outlined text-secondary text-sm" aria-hidden="true">check_circle</span> {t('sectores.bento.industrial.li2')}</li>
            <li class="flex items-center gap-2 text-sm font-bold text-on-surface"><span class="material-symbols-outlined text-secondary text-sm" aria-hidden="true">check_circle</span> {t('sectores.bento.industrial.li3')}</li>
            <li class="flex items-center gap-2 text-sm font-bold text-on-surface"><span class="material-symbols-outlined text-secondary text-sm" aria-hidden="true">check_circle</span> {t('sectores.bento.industrial.li4')}</li>
          </ul>
        </div>
        <div class="mt-auto flex items-center justify-between">
          <div class="text-sm font-bold text-secondary">{t('sectores.bento.industrial.case')}</div>
          <a href="#cotizacion" class="text-primary font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
            {t('sectores.bento.link')} <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
          </a>
        </div>
      </article>

      <!-- Sector Salud -->
      <article class="md:col-span-4 bg-primary text-white rounded-xl p-8 flex flex-col group hover:-translate-y-2 transition-transform duration-300">
        <div class="mb-6 flex justify-between">
          <span class="material-symbols-outlined text-4xl text-primary-fixed" aria-hidden="true">medical_services</span>
          <div class="bg-white/20 px-3 py-1 rounded-full text-xs font-bold">{t('sectores.bento.salud.badge')}</div>
        </div>
        <h3 class="font-headline text-2xl font-bold mb-4">{t('sectores.bento.salud.title')}</h3>
        <p class="text-white/80 mb-8 leading-relaxed">{t('sectores.bento.salud.body')}</p>
        <div class="mt-auto pt-6 border-t border-white/10">
          <p class="text-sm italic opacity-80">{t('sectores.bento.salud.footer')}</p>
        </div>
      </article>

      <!-- Sector Minero -->
      <article class="md:col-span-4 bg-tertiary text-white rounded-xl p-8 flex flex-col justify-between group hover:-translate-y-2 transition-transform duration-300">
        <div>
          <span class="material-symbols-outlined text-4xl mb-4 text-tertiary-fixed" aria-hidden="true">landscape</span>
          <h3 class="font-headline text-2xl font-bold mb-4">{t('sectores.bento.minero.title')}</h3>
          <p class="opacity-90 leading-relaxed">{t('sectores.bento.minero.body')}</p>
        </div>
        <div class="flex flex-wrap gap-2 mt-6">
          <span class="bg-tertiary-container/50 px-3 py-1 rounded-full text-xs font-bold">{t('sectores.bento.minero.tag1')}</span>
          <span class="bg-tertiary-container/50 px-3 py-1 rounded-full text-xs font-bold">{t('sectores.bento.minero.tag2')}</span>
        </div>
      </article>

      <!-- Sector Agroindustrial -->
      <article class="md:col-span-8 bg-surface-container-low rounded-xl border border-outline-variant p-8 flex flex-col md:flex-row gap-8 overflow-hidden group hover:-translate-y-2 transition-transform duration-300">
        <div class="flex-1 flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-secondary text-3xl" aria-hidden="true">agriculture</span>
              <h3 class="font-headline text-2xl font-bold text-on-surface">{t('sectores.bento.agro.title')}</h3>
            </div>
            <p class="text-on-surface-variant mb-6">{t('sectores.bento.agro.body')}</p>
            <div class="grid grid-cols-2 gap-4">
              {agroStats.map(stat => (
                <div class="bg-white p-4 rounded-lg border border-outline-variant/50">
                  <div class="text-secondary font-bold text-xl mb-1">{stat.value}</div>
                  <div class="text-xs text-on-surface-variant">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="hidden lg:block w-1/3 rounded-lg overflow-hidden shrink-0">
          <img
            src={agroImage}
            alt={t('sectores.bento.agro.img_alt')}
            class="w-full h-full object-cover"
            loading="lazy"
            width="300"
            height="400"
          />
        </div>
      </article>

    </div>
  </div>
</section>
