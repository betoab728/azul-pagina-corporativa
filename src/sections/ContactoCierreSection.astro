---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="pb-section-padding">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-primary-container rounded-3xl p-10 md:p-16 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="absolute -right-20 -top-20 w-64 h-64 rounded-full bg-on-primary-container/10 pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 max-w-2xl text-center md:text-left">
        <h2 class="font-headline text-4xl md:text-5xl text-on-primary-container font-extrabold mb-4">{t('contacto.cierre.title')}</h2>
        <p class="text-lg text-on-primary-container opacity-90 leading-relaxed">
          {t('contacto.cierre.subtitle')}
        </p>
      </div>

      <div class="relative z-10 shrink-0">
        <a
          href="#"
          class="inline-flex items-center bg-secondary-fixed text-on-secondary-fixed font-bold px-6 md:px-10 py-3 md:py-5 rounded-full hover:scale-105 transition-transform shadow-xl"
        >
          {t('contacto.cierre.btn')}
        </a>
      </div>
    </div>
  </div>
</section>
