---
import type { SupportedLocale } from '../i18n/utils'
// TODO: Reemplazar con imagen real del cliente
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuAZ0cXThiBZm3roLa-_6oaBFi8x3or7bYx17HkbR0Z83A_v4zi2OU6lBm1Pc3FvtnsSZsfT3QNNPg7Gya0YHIaQKS4cZDRvp-g9DQs38AXHTHQ4aYhtpILqjzSLd5Y4PpygSKkX794zV_PAy5FxNE3kLmM0AbVSBZgpJXPM8O7jYx1mroScYxWpdC9Hd1IfUW_ejA2bqapAu5LzHtTvwZmtgIhoYyiPCVTLUXNW8NR3Q7NJXf9CAXWeHFMO12qgYuksD0SPnGlGz_SQ'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---

<section id="proyectos-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="proyectos-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 opacity-80" style="background: linear-gradient(135deg, rgba(0, 71, 145, 0.9) 0%, rgba(0, 110, 7, 0.7) 100%);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">
        Compromiso Ambiental
      </span>
      <h1 id="proyectos-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-4">Casos de éxito</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed">Resultados que marcan la diferencia en la industria minera peruana a través de la gestión técnica y responsable.</p>
    </div>
  </div>
</section>