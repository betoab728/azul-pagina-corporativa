---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="cristobal-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid md:grid-cols-2 gap-6 items-center">
      <div>
        <h2 id="cristobal-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('cristobal.que_hicimos.title')}</h2>
        <div class="space-y-6 text-on-surface-variant">
          <p class="text-lg">
            {t('cristobal.que_hicimos.description')}
          </p>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary font-bold shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('cristobal.que_hicimos.item1')}</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary font-bold shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('cristobal.que_hicimos.item2')}</span>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary font-bold shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('cristobal.que_hicimos.item3')}</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-square rounded-xl overflow-hidden shadow-2xl">
          <img
            class="w-full h-full object-cover"
            alt={t('cristobal.que_hicimos.img_alt')}
            src="/sancristobal-hicimos.jpeg"
            loading="lazy"
            width="600"
            height="600"
          />
        </div>
        <div class="absolute -bottom-8 -left-8 p-6 rounded-xl shadow-lg max-w-[240px] border border-outline-variant/50" style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px);">
          <p class="font-headline text-xl font-bold text-primary mb-1">100%</p>
          <p class="text-sm text-on-surface-variant font-bold uppercase tracking-wider">{t('cristobal.que_hicimos.stat_label')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
