---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getValorItems } from '../data/almacenes-inteligentes'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const valorItems = getValorItems(lang)
---

<section class="py-section-padding bg-surface" aria-labelledby="almacenes-valor-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-8 md:gap-16">

      <div class="md:w-1/3">
        <h2 id="almacenes-valor-heading" class="font-headline text-4xl md:text-5xl font-extrabold md:sticky md:top-32">{t('almacenes.valor.title_1')} <span class="text-secondary">{t('almacenes.valor.title_highlight')}</span>?</h2>
        <p class="mt-4 text-on-surface-variant">{t('almacenes.valor.subtitle')}</p>
      </div>

      <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-8">
        {valorItems.map(item => (
          <div class="flex gap-4">
            <div class="text-primary font-bold text-xl shrink-0">{item.number}</div>
            <div class="space-y-2">
              <h4 class="font-bold">{item.title}</h4>
              <p class="text-sm text-on-surface-variant leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
