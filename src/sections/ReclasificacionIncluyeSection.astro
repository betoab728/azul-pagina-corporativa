---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getPilares } from '../data/reclasificacion'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const pilares = getPilares(lang)
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="reclasificacion-incluye-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop text-center mb-8 md:mb-16">
    <h2 id="reclasificacion-incluye-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold mb-4">{t('reclasificacion.incluye.title')}</h2>
    <div class="w-24 h-1 bg-secondary mx-auto rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {pilares.map(pilar => (
        <article class="bg-surface-container-lowest p-8 rounded-2xl border border-outline-variant hover:border-primary transition-all hover:shadow-xl group">
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-all text-primary">
            <span class="material-symbols-outlined text-3xl" aria-hidden="true">{pilar.icon}</span>
          </div>
          <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">{pilar.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{pilar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
