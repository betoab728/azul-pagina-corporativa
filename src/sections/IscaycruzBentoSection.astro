---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="iscaycruz-contenido-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 lg:col-span-8 bg-white border border-outline-variant rounded-xl p-10 flex flex-col justify-center shadow-sm relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-full transition-transform group-hover:scale-150 duration-500" aria-hidden="true"></div>
        <div class="flex items-start gap-6 mb-8">
          <div class="bg-primary-fixed p-4 rounded-lg text-primary">
            <span class="material-symbols-outlined text-[32px]" aria-hidden="true">engineering</span>
          </div>
          <div>
            <h2 id="iscaycruz-contenido-heading" class="font-headline text-4xl font-extrabold text-primary mb-2">{t('iscaycruz.bento.what_title')}</h2>
            <p class="text-on-surface-variant">{t('iscaycruz.bento.what_desc')}</p>
          </div>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="p-4 bg-surface-container-low rounded-lg border border-outline-variant/30">
            <div class="font-bold text-sm text-primary mb-2">{t('iscaycruz.bento.step1_label')}</div>
            <h4 class="font-headline text-lg font-bold mb-2">{t('iscaycruz.bento.step1_title')}</h4>
            <p class="text-sm text-on-surface-variant">{t('iscaycruz.bento.step1_desc')}</p>
          </div>
          <div class="p-4 bg-surface-container-low rounded-lg border border-outline-variant/30">
            <div class="font-bold text-sm text-primary mb-2">{t('iscaycruz.bento.step2_label')}</div>
            <h4 class="font-headline text-lg font-bold mb-2">{t('iscaycruz.bento.step2_title')}</h4>
            <p class="text-sm text-on-surface-variant">{t('iscaycruz.bento.step2_desc')}</p>
          </div>
          <div class="p-4 bg-surface-container-low rounded-lg border border-outline-variant/30">
            <div class="font-bold text-sm text-primary mb-2">{t('iscaycruz.bento.step3_label')}</div>
            <h4 class="font-headline text-lg font-bold mb-2">{t('iscaycruz.bento.step3_title')}</h4>
            <p class="text-sm text-on-surface-variant">{t('iscaycruz.bento.step3_desc')}</p>
          </div>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-4 bg-primary text-white rounded-xl p-8 relative overflow-hidden flex flex-col justify-end">
        <div class="absolute inset-0 opacity-20" aria-hidden="true">
          <img
            class="w-full h-full object-cover"
            alt=""
            src="/iscaycruz-hicimos.jpeg"
            loading="lazy"
            width="400"
            height="400"
          />
        </div>
        <div class="relative z-10">
          <h2 class="font-headline text-2xl font-bold mb-4">{t('iscaycruz.bento.resolution_title')}</h2>
          <ul class="space-y-4">
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary-container shrink-0" aria-hidden="true">check_circle</span>
              <p class="text-sm text-white/90">{t('iscaycruz.bento.resolution_item1')}</p>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary-container shrink-0" aria-hidden="true">check_circle</span>
              <p class="text-sm text-white/90">{t('iscaycruz.bento.resolution_item2')}</p>
            </li>
            <li class="flex gap-3">
              <span class="material-symbols-outlined text-secondary-container shrink-0" aria-hidden="true">check_circle</span>
              <p class="text-sm text-white/90">{t('iscaycruz.bento.resolution_item3')}</p>
            </li>
          </ul>
        </div>
      </div>

      <div class="col-span-12 md:col-span-6 bg-surface-container rounded-xl p-8 border border-outline-variant/50">
        <h2 class="font-headline text-2xl font-bold mb-6 flex items-center gap-3 text-primary">
          <span class="material-symbols-outlined" aria-hidden="true">analytics</span>
          {t('iscaycruz.bento.summary_title')}
        </h2>
        <div class="grid grid-cols-2 gap-6">
          <div class="text-center p-4">
            <div class="text-3xl font-extrabold text-primary mb-1">100%</div>
            <div class="text-xs uppercase tracking-tighter text-on-surface-variant/70">{t('iscaycruz.bento.stat1_label')}</div>
          </div>
          <div class="text-center p-4">
            <div class="text-3xl font-extrabold text-secondary mb-1">{t('iscaycruz.bento.stat2_value')}</div>
            <div class="text-xs uppercase tracking-tighter text-on-surface-variant/70">{t('iscaycruz.bento.stat2_label')}</div>
          </div>
        </div>
        <p class="mt-6 text-on-surface-variant leading-relaxed">
          {t('iscaycruz.bento.summary_desc')}
        </p>
      </div>

      <div class="col-span-12 md:col-span-6 rounded-xl overflow-hidden shadow-lg border border-outline-variant aspect-video max-h-80">
        <img
          alt={t('iscaycruz.bento.image_alt')}
          class="w-full h-full object-cover"
          src="/iscaycruz-hicimos.jpeg"
          loading="lazy"
          width="600"
          height="400"
        />
      </div>
    </div>
  </div>
</section>
