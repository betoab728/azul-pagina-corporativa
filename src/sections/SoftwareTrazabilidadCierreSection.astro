---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding bg-primary text-white text-center relative overflow-hidden" aria-labelledby="software-trazabilidad-cierre-heading">
  <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-secondary rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-tertiary rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-6">
    <h2 id="software-trazabilidad-cierre-heading" class="font-headline text-[32px] md:text-5xl font-extrabold mb-8">
      {t('software_trazabilidad.cierre.title')}
    </h2>

    <div class="flex flex-col md:flex-row justify-center items-center gap-6 mt-12">
      <a
        href="/contacto"
        class="inline-flex items-center bg-secondary text-white font-bold px-6 md:px-10 py-3 md:py-4 rounded-full hover:scale-105 transition-transform shadow-2xl text-xl"
      >
        {t('software_trazabilidad.cierre.cta_primary')}
      </a>
      <a
        href="/contacto"
        class="inline-flex items-center border-2 border-white text-white font-bold px-6 md:px-10 py-3 md:py-4 rounded-full hover:bg-white hover:text-primary transition-all text-xl"
      >
        {t('software_trazabilidad.cierre.cta_secondary')}
      </a>
    </div>
  </div>
</section>
