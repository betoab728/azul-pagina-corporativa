---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-lowest" aria-labelledby="chungar-resolucion-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-6 items-center">
      <div class="w-full md:w-1/2 order-2 md:order-1">
        <div class="relative inline-block">
          <div class="absolute -inset-4 bg-primary/5 rounded-full blur-3xl"></div>
          <img
            class="relative z-10 w-full aspect-square object-cover rounded-2xl border border-outline-variant shadow-xl"
            alt="Microscopio profesional enfocando muestra de laboratorio"
            src="/chungar-resolucion.jpeg"
            loading="lazy"
            width="600"
            height="600"
          />
        </div>
      </div>
      <div class="w-full md:w-1/2 order-1 md:order-2">
        <h2 id="chungar-resolucion-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('chungar.resolucion.title')}</h2>
        <div class="bg-surface-container-low p-8 rounded-xl border-l-4 border-secondary">
          <p class="text-on-surface italic mb-6">
            {t('chungar.resolucion.quote')}
          </p>
          <p class="text-on-surface-variant leading-relaxed">
            {t('chungar.resolucion.body')}
          </p>
        </div>
        <div class="mt-10 flex items-start gap-4">
          <div class="bg-secondary/10 p-3 rounded-full">
            <span class="material-symbols-outlined text-secondary" aria-hidden="true">gavel</span>
          </div>
          <div>
            <h4 class="text-on-surface font-bold">{t('chungar.resolucion.normativa.title')}</h4>
            <p class="text-on-surface-variant text-sm">{t('chungar.resolucion.normativa.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
