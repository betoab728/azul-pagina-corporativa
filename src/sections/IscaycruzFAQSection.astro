---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-bright" aria-labelledby="iscaycruz-faq-heading">
  <div class="max-w-[900px] mx-auto px-6">
    <div class="text-center mb-16">
      <h2 id="iscaycruz-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-4">{t('iscaycruz.faq.title')}</h2>
      <div class="w-20 h-1 bg-secondary mx-auto rounded-full"></div>
    </div>
    <div class="space-y-4">
      <details class="group bg-white border border-outline-variant rounded-xl overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold">{t('iscaycruz.faq.q1')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/20 pt-4">
          {t('iscaycruz.faq.a1')}
        </div>
      </details>
      <details class="group bg-white border border-outline-variant rounded-xl overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold">{t('iscaycruz.faq.q2')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/20 pt-4">
          {t('iscaycruz.faq.a2')}
        </div>
      </details>
      <details class="group bg-white border border-outline-variant rounded-xl overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold">{t('iscaycruz.faq.q3')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/20 pt-4">
          {t('iscaycruz.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
