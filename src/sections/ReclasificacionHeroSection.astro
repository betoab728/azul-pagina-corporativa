---
// TODO: Reemplazar con imagen real del cliente
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCqiqJ1oKHyDfMZ45KnQbrrLBMPr7B8r7WCnurYBz36EYa44wIC26oicLfiRQTqCUEeIqK8myADJrzxnM4lvU0oO-4J2FScC7deJaUnZ-GDKPgu4hPR65qPKbLVmcQQCilT8LvpIbYQ6l481BFUDmyuXPsfiEPI98Voz3d5vmFGsp3CsVsWILeCyGUDW02hrzjsMIfMshvLujgFN4ZIGgy9DwOytYXKL4na0THXiS7ExTTbDbulz3fuk2pr-zS6vIulC6NuISZf8Ycx'
---

<section id="reclasificacion-hero" class="relative h-[85vh] min-h-[600px] flex items-center overflow-hidden" aria-labelledby="reclasificacion-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/90 via-primary/40 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 bg-secondary-container text-on-secondary-container rounded-full text-sm font-bold mb-6">
        Soluciones de Ingeniería Ambiental
      </span>
      <h1 id="reclasificacion-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white mb-6 font-extrabold">
        Reclasificación de residuos peligrosos
      </h1>
      <p class="font-body text-lg text-white/90 mb-10 leading-relaxed max-w-xl">
        Reclasificación técnica para reducir costos y asegurar cumplimiento ambiental. Transformamos pasivos ambientales en eficiencia operativa sustentada.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="#cotizacion"
          class="inline-flex items-center gap-2 bg-secondary text-white font-bold px-8 py-4 rounded-full hover:shadow-lg transition-all active:scale-95 group"
        >
          Quiero reclasificar mis residuos
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>
