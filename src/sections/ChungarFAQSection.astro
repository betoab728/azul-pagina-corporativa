---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low" aria-labelledby="chungar-faq-heading">
  <div class="max-w-3xl mx-auto px-6">
    <h2 id="chungar-faq-heading" class="font-headline text-4xl font-extrabold text-primary text-center mb-12">{t('about.faq')}</h2>
    <div class="space-y-4">
      <details class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold text-on-surface">{t('chungar.faq.q1')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant pt-4">
          {t('chungar.faq.a1')}
        </div>
      </details>
      <details class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold text-on-surface">{t('chungar.faq.q2')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant pt-4">
          {t('chungar.faq.a2')}
        </div>
      </details>
      <details class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none hover:bg-surface-container-low transition-colors">
          <span class="font-headline text-lg font-bold text-on-surface">{t('chungar.faq.q3')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant pt-4">
          {t('chungar.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
