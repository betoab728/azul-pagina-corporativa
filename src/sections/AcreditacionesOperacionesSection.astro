---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const operacionesImage = '/acreditaciones-operaciones.jpeg'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="acreditaciones-operaciones-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-6 items-center bg-white border border-outline-variant p-6 md:p-10 rounded-2xl">

      <div class="w-full md:w-1/2">
        <img
          src={operacionesImage}
          alt={t('acreditaciones.operaciones.img_alt')}
          class="w-full h-64 md:h-80 object-cover rounded-xl shadow-lg"
          loading="lazy"
          width="600"
          height="320"
        />
      </div>

      <div class="w-full md:w-1/2">
        <h2 id="acreditaciones-operaciones-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-6 uppercase">
          {t('acreditaciones.operaciones.title')}
        </h2>
        <div class="mb-6">
          <div class="flex items-start gap-4 mb-6">
            <div class="bg-primary text-white p-2 rounded-lg shrink-0">
              <span class="material-symbols-outlined" aria-hidden="true">verified</span>
            </div>
            <div>
              <h4 class="font-headline text-2xl font-bold text-on-surface">{t('acreditaciones.operaciones.registro_title')}</h4>
              <p class="text-on-surface-variant mt-2 leading-relaxed">
                {t('acreditaciones.operaciones.registro_body')}
              </p>
            </div>
          </div>
          <div class="flex flex-wrap gap-4">
            <a
              href="/docs/pdf/alcances/1-ALCANCE-REGISTRO-AUTORITATIVO.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-secondary text-white font-bold px-6 py-3 rounded-full hover:opacity-90 transition-opacity text-sm uppercase tracking-wide"
            >
              {t('acreditaciones.operaciones.cta_alcance')}
              <span class="material-symbols-outlined text-sm" aria-hidden="true">launch</span>
            </a>
            <a
              href="/docs/pdf/alcances/2-Registro-Autoritativo.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-primary text-white font-bold px-6 py-3 rounded-full hover:opacity-90 transition-opacity text-sm uppercase tracking-wide"
            >
              {t('acreditaciones.operaciones.cta_registro')}
              <span class="material-symbols-outlined text-sm" aria-hidden="true">verified_user</span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
