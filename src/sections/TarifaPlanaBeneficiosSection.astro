---
import type { SupportedLocale } from '../i18n/utils'
import { getBeneficios } from '../data/tarifa-plana'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const beneficios = getBeneficios(lang)
---

<section class="py-section-padding bg-surface" aria-labelledby="tarifa-plana-beneficios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="tarifa-plana-beneficios-heading" class="font-headline text-4xl md:text-5xl text-primary text-center font-extrabold mb-8 md:mb-16">¿QUÉ GANA TU EMPRESA?</h2>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
      {beneficios.map(beneficio => (
        <div class="text-center p-6 flex flex-col items-center">
          <div class="mb-4 text-secondary">
            <span class="material-symbols-outlined text-[48px]" aria-hidden="true">{beneficio.icon}</span>
          </div>
          <div class="font-bold text-sm text-on-surface">{beneficio.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>