---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low" aria-labelledby="americana-faq-heading">
  <div class="max-w-4xl mx-auto px-6">
    <h2 id="americana-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('americana.faq.title')}</h2>
    <div class="space-y-4">
      <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 overflow-hidden" open>
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none select-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('americana.faq.q1')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
          {t('americana.faq.a1')}
        </div>
      </details>
      <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none select-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('americana.faq.q2')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
          {t('americana.faq.a2')}
        </div>
      </details>
      <details class="group bg-surface-container-lowest rounded-xl border border-outline-variant/20 overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none select-none">
          <span class="font-headline text-lg font-bold text-on-surface">{t('americana.faq.q3')}</span>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant leading-relaxed">
          {t('americana.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
