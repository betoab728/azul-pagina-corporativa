---
import { complianceItems } from '../data/acreditaciones'
---

<section class="py-section-padding bg-surface" aria-labelledby="acreditaciones-compliance-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16">
      <h2 id="acreditaciones-compliance-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold mb-6 uppercase tracking-wider">
        Cumplimiento Garantizado con la Normativa Ambiental Vigente
      </h2>
      <p class="text-lg text-secondary font-bold">
        Tu empresa opera sin riesgos, multas ni observaciones.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {complianceItems.map(item => (
        <article class="bg-white border border-outline-variant p-6 rounded-xl hover:shadow-xl hover:-translate-y-0.5 transition-all flex flex-col h-full">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-[40px]" aria-hidden="true">{item.icon}</span>
          </div>
          <h3 class="font-headline text-2xl font-bold text-primary mb-4">{item.title}</h3>
          <p class="text-on-surface-variant leading-relaxed flex-grow mb-6">{item.description}</p>
          <a
            href={item.pdfUrl}
            class="w-full py-2 border border-primary text-primary font-bold text-sm rounded-full hover:bg-primary hover:text-white transition-all flex items-center justify-center gap-2"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">picture_as_pdf</span>
            Abrir PDF
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
