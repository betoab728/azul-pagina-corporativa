---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding bg-on-surface" aria-labelledby="recursos-newsletter-heading">
  <div class="max-w-3xl mx-auto px-6 text-center space-y-8">
    <h2 id="recursos-newsletter-heading" class="font-headline text-[32px] md:text-5xl text-white font-extrabold">{t('recursos.newsletter.title')}</h2>
    <p class="text-lg text-surface-variant">{t('recursos.newsletter.subtitle')}</p>
    <form class="flex flex-col sm:flex-row gap-4" novalidate>
      <input
        class="flex-grow rounded-lg bg-inverse-surface border border-outline-variant text-white p-4 focus:ring-2 focus:ring-primary/20 outline-none"
        placeholder={t('recursos.newsletter.placeholder')}
        type="email"
      />
      <button
        type="submit"
        class="inline-flex items-center bg-secondary text-white font-bold px-6 md:px-8 py-3 md:py-4 rounded-lg hover:scale-105 transition-all shrink-0"
      >
        {t('recursos.newsletter.cta')}
      </button>
    </form>
  </div>
</section>
