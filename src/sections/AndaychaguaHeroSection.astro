---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = '/andachagua.jpeg'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section class="py-20" style="background: linear-gradient(135deg, rgba(0, 71, 145, 0.05) 0%, rgba(146, 251, 127, 0.05) 100%);" aria-labelledby="andaychagua-hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
      <div class="space-y-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 text-primary rounded-full border border-primary/20">
          <span class="material-symbols-outlined text-[18px]" aria-hidden="true">verified</span>
          <span class="font-bold text-sm">{t('andaychagua.hero.badge')}</span>
        </div>
        <h1 id="andaychagua-hero-heading" class="font-headline text-4xl md:text-5xl font-extrabold text-primary leading-tight">
          {t('andaychagua.hero.title')} - <span class="text-secondary">{t('projects.badge')}</span>
        </h1>
        <p class="font-body text-lg text-on-surface-variant max-w-xl leading-relaxed">
          {t('andaychagua.hero.description')}
        </p>
      </div>
      <div class="relative rounded-xl overflow-hidden shadow-xl aspect-video lg:aspect-square">
        <img
          src={heroImage}
          alt={t('andaychagua.hero.img_alt')}
          class="w-full h-full object-cover"
          loading="eager"
          width="800"
          height="800"
        />
      </div>
    </div>
  </div>
</section>