---
import type { SupportedLocale } from '../i18n/utils'
import { getProblemas } from '../data/almacenes-inteligentes'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const problemas = getProblemas(lang)
---

<section class="py-section-padding bg-surface" aria-labelledby="almacenes-problema-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">

      <div class="space-y-6">
        <div class="inline-block px-4 py-1 bg-error-container text-on-error-container rounded-full text-xs font-bold uppercase tracking-wider">
          ¿Por qué es importante?
        </div>
        <h2 id="almacenes-problema-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold">
          Su almacén de residuos no es una obligación, es una <span class="text-primary">fuente de ingresos oculta</span>.
        </h2>
        <p class="text-on-surface-variant leading-relaxed">
          Muchas empresas ven el almacenamiento de descartes como un costo hundido. En Azul Sostenible, identificamos los puntos de fuga financiera que impactan su rentabilidad diaria.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {problemas.map(item => (
          <div class="p-6 bg-white border border-outline-variant rounded-xl hover:border-error transition-colors group">
            <span class="material-symbols-outlined text-error mb-4 block group-hover:scale-110 transition-transform" aria-hidden="true">{item.icon}</span>
            <h3 class="font-bold text-on-surface">{item.title}</h3>
            <p class="text-sm text-on-surface-variant">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>