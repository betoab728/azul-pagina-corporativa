---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low relative overflow-hidden" aria-labelledby="carahuacra-resolucion-heading">
  <div class="absolute inset-0 opacity-5" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary rounded-full blur-3xl"></div>
  </div>
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop relative z-10">
    <div class="bg-surface-container-lowest border border-outline-variant p-12 md:p-16 rounded-3xl shadow-sm">
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="bg-primary-container p-6 rounded-2xl">
          <span class="material-symbols-outlined text-white text-6xl" aria-hidden="true">gavel</span>
        </div>
        <div class="flex-1">
          <h2 id="carahuacra-resolucion-heading" class="font-headline text-4xl font-extrabold text-primary mb-6">{t('carahuacra.resolucion.title')}</h2>
          <p class="text-lg text-on-surface mb-8 leading-relaxed">
            {t('carahuacra.resolucion.description')}
          </p>
          <div class="inline-flex items-center gap-4 bg-secondary-container px-8 py-6 rounded-2xl">
            <span class="material-symbols-outlined text-on-secondary-container text-4xl shrink-0" aria-hidden="true" style="font-variation-settings: 'FILL' 1;">verified</span>
            <div>
              <p class="font-headline text-2xl font-bold text-on-secondary-container">{t('carahuacra.resolucion.status_title')}</p>
              <p class="text-on-secondary-container/80">{t('carahuacra.resolucion.status_desc')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
