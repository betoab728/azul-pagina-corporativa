---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-low" aria-labelledby="andaychagua-faq-heading">
  <div class="max-w-[800px] mx-auto px-6">
    <h2 id="andaychagua-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('about.faq')}</h2>
    <div class="space-y-4">
      <details class="group bg-white rounded-xl border border-outline-variant overflow-hidden" open>
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg text-primary font-bold">{t('andaychagua.faq.q1')}</span>
          <span class="material-symbols-outlined transition-transform group-open:rotate-180 shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant">
          {t('andaychagua.faq.a1')}
        </div>
      </details>
      <details class="group bg-white rounded-xl border border-outline-variant overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg text-primary font-bold">{t('andaychagua.faq.q2')}</span>
          <span class="material-symbols-outlined transition-transform group-open:rotate-180 shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant">
          {t('andaychagua.faq.a2')}
        </div>
      </details>
      <details class="group bg-white rounded-xl border border-outline-variant overflow-hidden">
        <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
          <span class="font-headline text-lg text-primary font-bold">{t('andaychagua.faq.q3')}</span>
          <span class="material-symbols-outlined transition-transform group-open:rotate-180 shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant">
          {t('andaychagua.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
