---
import { casosExito } from '../data/reclasificacion'
---

<section class="py-section-padding bg-tertiary text-white" aria-labelledby="reclasificacion-casos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="reclasificacion-casos-heading" class="font-headline text-4xl md:text-5xl font-extrabold mb-12 text-center">Casos de Éxito - Resoluciones Obtenidas</h2>

    <div class="space-y-4">
      {casosExito.map(caso => (
        <div class="flex flex-col md:flex-row md:items-center justify-between p-6 bg-white/5 border border-white/20 rounded-xl hover:bg-white/10 transition-all">
          <div class="flex items-center gap-4 mb-4 md:mb-0">
            <span class="material-symbols-outlined text-secondary-fixed shrink-0" aria-hidden="true">{caso.pdfIcon}</span>
            <p class="text-white break-words">{caso.title}</p>
          </div>
          <a
            href={caso.pdfUrl}
            class="flex items-center gap-2 text-secondary-fixed font-bold hover:underline shrink-0"
          >
            Abrir PDF
            <span class="material-symbols-outlined text-sm" aria-hidden="true">open_in_new</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
