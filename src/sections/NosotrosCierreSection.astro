---
import type { SupportedLocale } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---
<section class="py-section-padding" aria-labelledby="nosotros-cierre-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-primary rounded-[40px] overflow-hidden relative shadow-2xl">
      <div class="absolute inset-0 opacity-10 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-secondary rounded-full blur-[100px]"></div>
      </div>
      <div class="relative z-10 px-6 py-12 md:px-20 md:py-20 text-center">
        <h3 id="nosotros-cierre-heading" class="font-headline text-[32px] md:text-5xl text-white font-extrabold mb-8 uppercase">LAS EMPRESAS INTELIGENTES GESTIONAN RESIDUOS, LAS EMPRESAS LÍDERES GESTIONAN IMPACTO</h3>
        <div class="flex flex-col md:flex-row gap-6 justify-center">
          <a
            href="/"
            class="inline-flex items-center gap-3 bg-secondary text-white font-bold px-6 md:px-10 py-3 md:py-5 rounded-full hover:scale-105 transition-transform shadow-lg"
          >
            Solicitar Cotización
            <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
