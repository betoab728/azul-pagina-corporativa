---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuAvx7jLKiMVEj9LJRb3O7sqEwjBp-YFV6rujaas4ZrNBff1ihq1IhPp--V9_lw1bOk0W81SoeiWqxTGzRqFwaxJGfE5-P9pyVUte3X5pfRaX89eA-5mD-1LTLgDqQ-B06TI8rZ4CAEcNzA24bkjUwIXWoVeaISMXqakYvQtkKJa387ElTcwsb2r5uvoRvr1X1qXkNJYjq_d-2vxZ0yEBJBcoatckGPB44_XmtwkrO_nBWtUXaHDqlSqqmz009FJiLGf7fdIGpTjrUUP'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="software-trazabilidad-hero" class="relative min-h-[85vh] flex items-center pt-20 overflow-hidden" aria-labelledby="software-trazabilidad-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/90 to-primary/40"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container font-bold text-sm mb-6">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">cloud_sync</span>
        {t('software_trazabilidad.hero.badge')}
      </div>

      <h1 id="software-trazabilidad-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-on-primary mb-6 font-extrabold">
        {t('software_trazabilidad.hero.title')}
      </h1>

      <p class="font-body text-lg text-on-primary/90 mb-10 max-w-xl leading-relaxed">
        {t('software_trazabilidad.hero.subtitle')}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 bg-secondary text-white font-bold px-6 md:px-8 py-3 md:py-4 rounded-full hover:scale-[1.02] transition-transform shadow-lg"
        >
          {t('software_trazabilidad.hero.cta')}
          <span class="material-symbols-outlined text-xl" aria-hidden="true">login</span>
        </a>
      </div>
    </div>
  </div>
</section>
