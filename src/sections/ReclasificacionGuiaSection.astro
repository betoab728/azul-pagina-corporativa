---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const guiaImage = '/guia-caracterizacion.jpeg'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section class="py-section-padding bg-surface" aria-labelledby="reclasificacion-guia-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-[#f0f4fa] border border-outline-variant/20 rounded-3xl p-8 md:p-12 lg:p-16">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 md:gap-12 items-center">

      <!-- Imagen (3/5 del ancho para darle más protagonismo) -->
      <div class="lg:col-span-3 relative">
        <div class="absolute -inset-4 bg-primary/5 rounded-2xl -z-10" aria-hidden="true"></div>
        <div class="rounded-2xl overflow-hidden shadow-xl border border-outline-variant/30">
          <img
            src={guiaImage}
            alt={t('reclasificacion.guia.img_alt')}
            class="w-full h-[320px] md:h-[450px] lg:h-[520px] object-cover object-center"
            loading="lazy"
            width="700"
            height="520"
          />
        </div>
        <div class="absolute -bottom-4 -right-4 bg-secondary-container/20 rounded-xl px-4 py-3 border border-secondary/10 shadow-sm">
          <div class="flex items-center gap-2 text-on-secondary-container">
            <span class="material-symbols-outlined text-secondary" aria-hidden="true">verified</span>
            <span class="text-xs font-bold">{t('reclasificacion.guia.badge')}</span>
          </div>
        </div>
      </div>

      <!-- Contenido (2/5) -->
      <div class="lg:col-span-2 space-y-5">
        <span class="text-primary font-bold text-sm uppercase tracking-widest">{t('reclasificacion.guia.label')}</span>
        <h2 id="reclasificacion-guia-heading" class="font-headline text-2xl md:text-3xl lg:text-4xl text-primary font-extrabold leading-tight">
          {t('reclasificacion.guia.title')}
        </h2>
        <p class="text-sm md:text-base text-on-surface-variant leading-relaxed">
          {t('reclasificacion.guia.intro')}
        </p>

        <!-- Pasos clave compactos -->
        <div class="space-y-3">
          <div class="flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-outline-variant/50">
            <div class="w-8 h-8 bg-primary text-white rounded-lg flex items-center justify-center shrink-0 text-sm font-bold">1</div>
            <span class="text-sm font-bold text-on-surface">{t('reclasificacion.guia.step1_title')}</span>
          </div>
          <div class="flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-outline-variant/50">
            <div class="w-8 h-8 bg-primary text-white rounded-lg flex items-center justify-center shrink-0 text-sm font-bold">2</div>
            <span class="text-sm font-bold text-on-surface">{t('reclasificacion.guia.step2_title')}</span>
          </div>
          <div class="flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-outline-variant/50">
            <div class="w-8 h-8 bg-primary text-white rounded-lg flex items-center justify-center shrink-0 text-sm font-bold">3</div>
            <span class="text-sm font-bold text-on-surface">{t('reclasificacion.guia.step3_title')}</span>
          </div>
          <div class="flex items-center gap-3 p-3 bg-surface-container-low rounded-xl border border-outline-variant/50">
            <div class="w-8 h-8 bg-primary text-white rounded-lg flex items-center justify-center shrink-0 text-sm font-bold">4</div>
            <span class="text-sm font-bold text-on-surface">{t('reclasificacion.guia.step4_title')}</span>
          </div>
        </div>

        <!-- Beneficios (3 puntos) -->
        <ul class="space-y-2" aria-label={t('reclasificacion.guia.benefits_list_label')}>
          <li class="flex items-start gap-3 text-on-surface-variant text-sm">
            <span class="material-symbols-outlined text-secondary shrink-0 mt-0.5" aria-hidden="true">check_circle</span>
            <span>{t('reclasificacion.guia.benefit1')}</span>
          </li>
          <li class="flex items-start gap-3 text-on-surface-variant text-sm">
            <span class="material-symbols-outlined text-secondary shrink-0 mt-0.5" aria-hidden="true">check_circle</span>
            <span>{t('reclasificacion.guia.benefit2')}</span>
          </li>
          <li class="flex items-start gap-3 text-on-surface-variant text-sm">
            <span class="material-symbols-outlined text-secondary shrink-0 mt-0.5" aria-hidden="true">check_circle</span>
            <span>{t('reclasificacion.guia.benefit3')}</span>
          </li>
        </ul>
      </div>

    </div>
    </div>
  </div>
</section>
