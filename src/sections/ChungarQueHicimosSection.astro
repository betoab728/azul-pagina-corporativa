---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="chungar-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      <div class="md:col-span-7 flex flex-col justify-center">
        <h2 id="chungar-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('chungar.que_hicimos.title')}</h2>
        <div class="space-y-6">
          <p class="text-on-surface-variant leading-relaxed">
            {t('chungar.que_hicimos.intro')}
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-8">
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant hover:shadow-lg transition-shadow">
              <span class="material-symbols-outlined text-primary text-4xl mb-4 block" aria-hidden="true">analytics</span>
              <h3 class="font-headline text-2xl font-bold text-primary mb-2">{t('chungar.que_hicimos.card1.title')}</h3>
              <p class="text-on-surface-variant text-sm">{t('chungar.que_hicimos.card1.desc')}</p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant hover:shadow-lg transition-shadow">
              <span class="material-symbols-outlined text-secondary text-4xl mb-4 block" aria-hidden="true">science</span>
              <h3 class="font-headline text-2xl font-bold text-secondary mb-2">{t('chungar.que_hicimos.card2.title')}</h3>
              <p class="text-on-surface-variant text-sm">{t('chungar.que_hicimos.card2.desc')}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 relative h-[500px] rounded-2xl overflow-hidden group">
        <img
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          alt="Laboratorio moderno con científicos realizando análisis químico"
          src="/chungar-hicimos.jpeg"
          loading="lazy"
          width="600"
          height="500"
        />
        <div class="absolute bottom-6 left-6 right-6 p-6 rounded-xl border border-white/20" style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px);">
          <p class="text-primary font-headline text-2xl font-bold">100%</p>
          <p class="text-on-surface-variant text-sm">{t('chungar.que_hicimos.trazabilidad')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
