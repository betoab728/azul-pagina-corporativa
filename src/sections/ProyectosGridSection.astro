---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getProjectsData, getAlsoTrusted } from '../data/proyectos-page'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const projectsData = getProjectsData(lang)
const alsoTrusted = getAlsoTrusted(lang)
---

<section class="py-section-padding" aria-labelledby="proyectos-grid-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="mb-8 md:mb-16">
      <h2 id="proyectos-grid-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">{t('proyectos.grid.title')}</h2>
      <p class="text-on-surface-variant max-w-3xl">{t('proyectos.grid.body')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projectsData.map(project => (
        <article class="group bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
          <div class="h-48 overflow-hidden relative">
            <img
              src={project.image}
              alt={project.imageAlt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              width="400"
              height="192"
            />
            <div class="absolute top-4 left-4 bg-primary text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">{project.sector}</div>
          </div>
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex items-center gap-2 mb-4 text-secondary">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{project.icon}</span>
              <h3 class="font-headline text-2xl font-bold">{project.title}</h3>
            </div>
            <ul class="space-y-4 text-on-surface-variant flex-grow">
              {project.items.map(item => (
                <li class="flex gap-3">
                  <span class="material-symbols-outlined text-primary shrink-0" aria-hidden="true">check_circle</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-6 pt-6 border-t border-outline-variant/30">
              <a
                href={`/proyectos/${project.slug || '#'}`}
                class="w-full bg-primary text-on-primary px-6 py-3 rounded-lg font-bold hover:bg-primary-container transition-colors flex items-center justify-center gap-2"
              >
                <span>{t('proyectos.grid.card_cta')}</span>
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-20 p-6 md:p-10 border border-secondary/20 bg-secondary/5 rounded-2xl flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h4 class="font-headline text-2xl font-bold text-primary mb-2">{t('proyectos.grid.also_trusted_title')}</h4>
        <p class="text-on-surface-variant">{t('proyectos.grid.also_trusted_body')}</p>
      </div>
      <div class="flex flex-wrap gap-4">
        {alsoTrusted.map(company => (
          company.slug ? (
            <a href={`/proyectos/${company.slug}`} class="px-6 py-3 bg-white border border-outline-variant rounded-lg font-bold text-primary shadow-sm hover:border-primary hover:shadow-md transition-all">
              {company.name}
            </a>
          ) : (
            <span class="px-6 py-3 bg-white border border-outline-variant rounded-lg font-bold text-primary shadow-sm">{company.name}</span>
          )
        ))}
      </div>
    </div>
  </div>
</section>
