---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getSectoresNosotros } from '../data/nosotros'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const sectoresNosotros = getSectoresNosotros(lang)
---

<section class="py-section-padding" aria-labelledby="nosotros-sectores-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16">
      <h2 id="nosotros-sectores-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">{t('nosotros.sectores.title')}</h2>
      <div class="w-24 h-1 bg-secondary mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {sectoresNosotros.map(sector => (
        <div class="bg-surface border border-outline-variant p-8 rounded-xl hover:shadow-lg transition-all">
          <div class="flex items-center gap-4 mb-4">
            {sector.icon && (
              <span class="material-symbols-outlined text-primary text-[40px]" aria-hidden="true">{sector.icon}</span>
            )}
            <h4 class="font-headline text-2xl font-bold text-primary">{sector.title}</h4>
          </div>
          <p class="text-on-surface-variant leading-relaxed">{sector.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>