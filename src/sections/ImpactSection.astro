---
import ImpactCounter from '../components/blocks/ImpactCounter.astro'
import { impactStats } from '../data/impact'
---

<section class="py-20 bg-white" aria-labelledby="impact-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-white border border-outline-variant/20 rounded-2xl shadow-lg p-10">
      <div class="text-center mb-8">
        <p class="text-on-surface-variant font-bold text-sm uppercase tracking-widest">TÚ PODRÍAS SER EL PRÓXIMO</p>
        <a
          href="#cotizacion"
          class="inline-block bg-secondary text-white text-xs font-bold px-6 py-2 rounded-full mt-2 hover:bg-secondary/90 transition-all"
        >
          SOLICITA UNA COTIZACIÓN
        </a>
      </div>

      <div
        id="impact-heading"
        class="flex flex-wrap divide-x divide-outline-variant/30"
        aria-label="Estadísticas de impacto"
      >
        {impactStats.map(stat => (
          <div class="w-1/2 lg:w-1/4 px-4 md:px-8 py-4 flex justify-center">
            <ImpactCounter {...stat} />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
