---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getImpactStats } from '../data/impact'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const impactStats = getImpactStats(lang)
const parsedStats = impactStats.map(stat => {
  const numeric = parseInt(stat.value.replace(/[^0-9]/g, ''), 10)
  const prefix = stat.value.startsWith('+') ? '+' : ''
  return { ...stat, target: numeric, prefix }
})
---

<section class="py-20 bg-white" aria-labelledby="impact-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-white border border-outline-variant/20 rounded-2xl shadow-lg p-10">
      <div class="text-center mb-8">
        <p class="text-on-surface-variant font-bold text-sm uppercase tracking-widest">{t('impact.prompt')}</p>
        <a
          href="#cotizacion"
          class="inline-block bg-secondary text-white text-xs font-bold px-6 py-2 rounded-full mt-2 hover:bg-secondary/90 transition-all"
        >
          {t('impact.cta')}
        </a>
      </div>

      <div
        id="impact-counters"
        class="flex flex-wrap divide-x divide-outline-variant/30"
        aria-label="Estadísticas de impacto"
      >
        {parsedStats.map((stat, i) => {
          const iconColorClass = stat.iconColor === 'primary' ? 'text-primary' : 'text-secondary'
          return (
            <div
              class="w-1/2 lg:w-1/4 px-4 md:px-8 py-4 flex justify-center counter-item opacity-0 translate-y-5"
              style={`transition: opacity 0.7s ease, transform 0.7s ease; transition-delay: ${i * 120}ms`}
            >
              <div class="flex flex-col items-center">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`material-symbols-outlined ${iconColorClass} text-3xl`} aria-hidden="true">{stat.icon}</span>
                  <span class="counter-value text-3xl font-extrabold" data-target={String(stat.target)} data-prefix={stat.prefix}>0</span>
                </div>
                <p class="text-xs text-on-surface-variant font-semibold text-center">{stat.label}</p>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>

<script>
  function formatNumber(n: number): string {
    return n.toLocaleString('en-US')
  }

  function animateCounter(el: HTMLElement, target: number, prefix: string, duration: number) {
    const start = performance.now()

    function tick(now: number) {
      const elapsed = now - start
      const progress = Math.min(elapsed / duration, 1)
      const eased = 1 - (1 - progress) * (1 - progress)
      const current = Math.round(eased * target)
      el.textContent = prefix + formatNumber(current)

      if (progress < 1) {
        requestAnimationFrame(tick)
      } else {
        el.textContent = prefix + formatNumber(target)
      }
    }

    requestAnimationFrame(tick)
  }

  let animated = false

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !animated) {
          animated = true
          const container = entry.target as HTMLElement

          const items = container.querySelectorAll<HTMLElement>('.counter-item')
          items.forEach((item) => {
            item.classList.remove('opacity-0', 'translate-y-5')
            item.classList.add('opacity-100', 'translate-y-0')
          })

          const values = container.querySelectorAll<HTMLElement>('.counter-value')
          values.forEach((el) => {
            const target = parseInt(el.dataset.target || '0', 10)
            const prefix = el.dataset.prefix || ''
            animateCounter(el, target, prefix, 1800)
          })

          observer.unobserve(container)
        }
      })
    },
    { threshold: 0.3 }
  )

  const root = document.getElementById('impact-counters')
  if (root) observer.observe(root)
</script>