<section id="morococha-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="morococha-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0, 71, 145, 0.8), rgba(0, 71, 145, 0.1));"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold uppercase tracking-wider">
        Proyecto de Evaluación Técnica
      </span>
      <h1 id="morococha-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-4">UM. MOROCOCHA - Casos de éxito</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed">Ingeniería y sostenibilidad aplicadas a la gestión avanzada de residuos en la industria minera. Un enfoque técnico para la desclasificación de peligrosidad.</p>
    </div>
  </div>
