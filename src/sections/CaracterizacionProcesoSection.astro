---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const procesoImage = '/diagnostico.jpeg'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="proceso-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop flex flex-col md:flex-row gap-8 md:gap-16 items-center">
    <div class="w-full md:w-1/2 order-2 md:order-1">
      <img
        src={procesoImage}
        alt={t('caracterizacion.proceso.img_alt')}
        class="rounded-xl border border-outline-variant shadow-2xl w-full h-[350px] md:h-[450px] object-cover"
        loading="lazy"
        width="600"
        height="400"
      />
    </div>

    <div class="w-full md:w-1/2 space-y-6 order-1 md:order-2">
      <span class="text-primary font-bold text-sm uppercase tracking-widest">{t('caracterizacion.proceso.label')}</span>
      <h2 id="proceso-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold">{t('caracterizacion.proceso.title')}</h2>
      <div class="space-y-4 text-on-surface-variant leading-relaxed">
        <p>{t('caracterizacion.proceso.body1')}</p>
        <p class="font-bold text-primary text-xl border-l-4 border-secondary pl-4">{t('caracterizacion.proceso.quote')}</p>
        <p>{t('caracterizacion.proceso.body2')}</p>
      </div>
    </div>
  </div>
</section>
