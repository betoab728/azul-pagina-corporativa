---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section id="acreditaciones-hero" class="py-section-padding relative overflow-hidden" style="background: linear-gradient(135deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.45) 100%), url('/acreditaciones-fondo.jpeg') center/cover no-repeat;" aria-labelledby="acreditaciones-hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop relative z-10">
    <div class="max-w-3xl py-15">
      <span class="inline-block py-1 px-3 bg-white/20 text-white rounded-full text-sm font-bold mb-6">
        {t('acreditaciones.hero.badge')}
      </span>
      <h1 id="acreditaciones-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-6">
        {t('acreditaciones.hero.title')}
      </h1>
      <p class="font-body text-lg text-white/80 leading-relaxed">
        {t('acreditaciones.hero.body')}
      </p>
    </div>
  </div>
</section>
