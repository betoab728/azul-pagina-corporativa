---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container" aria-labelledby="morococha-resolucion-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <h2 id="morococha-resolucion-heading" class="font-headline text-4xl font-extrabold text-primary mb-4">{t('morococha.resolucion.title')}</h2>
      <p class="text-lg text-on-surface-variant max-w-2xl mx-auto">{t('morococha.resolucion.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2 bg-white p-8 rounded-xl border border-outline-variant hover:shadow-xl transition-all flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-2 text-secondary mb-4">
            <span class="material-symbols-outlined" aria-hidden="true">science</span>
            <span class="font-bold text-sm">{t('morococha.resolucion.lab_label')}</span>
          </div>
          <h3 class="font-headline text-2xl font-bold mb-4">{t('morococha.resolucion.lab_title')}</h3>
          <p class="text-on-surface-variant mb-6 leading-relaxed">
            {t('morococha.resolucion.lab_body')}
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="px-4 py-1 bg-surface-container-low rounded-full font-bold text-sm text-primary">{t('morococha.resolucion.badge1')}</span>
          <span class="px-4 py-1 bg-surface-container-low rounded-full font-bold text-sm text-primary">{t('morococha.resolucion.badge2')}</span>
        </div>
      </div>
      <div class="bg-primary text-white p-8 rounded-xl flex flex-col">
        <span class="material-symbols-outlined text-4xl mb-4" aria-hidden="true">gavel</span>
        <h3 class="font-headline text-2xl font-bold mb-4">{t('morococha.resolucion.legal_title')}</h3>
        <p class="text-white/80 leading-relaxed mb-6 flex-grow">
          {t('morococha.resolucion.legal_body')}
        </p>
        <div class="pt-4 border-t border-white/20">
          <span class="font-bold text-sm">{t('morococha.resolucion.compliance')}</span>
        </div>
      </div>
      <div class="md:col-span-3 bg-white p-12 rounded-xl border border-outline-variant flex flex-col md:flex-row items-center gap-12">
        <div class="flex-1">
          <h3 class="font-headline text-4xl font-extrabold text-primary mb-6">{t('morococha.resolucion.summary_title')}</h3>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            {t('morococha.resolucion.summary_body')}
          </p>
        </div>
        <div class="w-64 h-64 bg-secondary-container rounded-full flex items-center justify-center p-8 text-center shrink-0">
          <div>
            <span class="material-symbols-outlined text-5xl text-on-secondary-container mb-2 block" aria-hidden="true">check_circle</span>
            <div class="font-headline text-2xl font-bold text-on-secondary-container">{t('morococha.resolucion.success_label')}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
