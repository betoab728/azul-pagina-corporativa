---
import type { SupportedLocale } from '../i18n/utils'
import { getLogisticas } from '../data/acreditaciones'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const logisticas = getLogisticas(lang)
---

<section class="py-section-padding bg-surface" aria-labelledby="acreditaciones-logistica-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex justify-between items-end mb-8 md:mb-16">
      <div class="max-w-2xl">
        <h2 id="acreditaciones-logistica-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold uppercase">
          Capacidad Logística y Operativa Certificada
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {logisticas.map(item => (
        <article class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl flex flex-col text-center items-center">
          <div class="w-16 h-16 rounded-full bg-primary-fixed-dim text-primary flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-3xl" aria-hidden="true">{item.icon}</span>
          </div>
          <h3 class="font-headline text-2xl font-bold text-primary mb-4">{item.title}</h3>
          <p class="text-on-surface-variant leading-relaxed mb-6">{item.description}</p>
          <a
            href={item.pdfUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto text-primary font-bold text-sm hover:underline flex items-center gap-1"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">open_in_new</span>
            Abrir PDF
          </a>
        </article>
      ))}
    </div>
  </div>
</section>