---
import { beneficios } from '../data/reclasificacion'
---

<section class="py-section-padding bg-surface overflow-hidden" aria-labelledby="reclasificacion-beneficios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row gap-6 md:gap-12 items-start">

      <div class="md:w-1/3">
        <h2 id="reclasificacion-beneficios-heading" class="font-headline text-4xl md:text-5xl text-on-surface font-extrabold md:sticky md:top-32">¿Qué gana tu empresa con nosotros?</h2>
      </div>

      <div class="md:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-6">
        {beneficios.map(beneficio => (
          beneficio.destacado ? (
            <div class="md:col-span-2 p-6 bg-primary/5 border-2 border-primary/20 rounded-xl flex gap-4 items-center">
              <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{beneficio.icon}</span>
              <div>
                <p class="font-bold text-lg">{beneficio.title}</p>
                <p class="text-on-surface-variant text-sm">{beneficio.description}</p>
              </div>
            </div>
          ) : (
            <div class="p-6 bg-white border border-outline-variant rounded-xl flex gap-4 items-start shadow-sm hover:shadow-md transition-shadow">
              <span class="material-symbols-outlined text-secondary shrink-0" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{beneficio.icon}</span>
              <div>
                <p class="font-bold text-lg mb-1">{beneficio.title}</p>
                <p class="text-on-surface-variant text-sm">{beneficio.description}</p>
              </div>
            </div>
          )
        ))}
      </div>

    </div>
  </div>
</section>
