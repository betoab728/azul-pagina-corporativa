---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCIUVG6S_qyL8BVujxbWY5TrQlYgmODicOXM7JKWWEeo_hd3YMo7FIJBRLIX2WAfLAOJug8SD0-9HnrXOiYtG6ANYe2r839tHZJKy3Mr78X4uxVVUA_i6hrs3iZt7zBVW2tYDaNMQLtw8phwoQJnsECP6XYWuh6eeqKzyt8r5l4TAAIFUOMkCLIiIqvE58tV3gukDaqg0lUKDo76yPv2AeUe_GKfnhsHgoW23fIG3EsEuanGtk1NzJW5GYkzLh_0M8b9MpS2htA_Lhx'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="carahuacra-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="carahuacra-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0, 71, 145, 0.9), rgba(0, 110, 7, 0.4));"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full text-white">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary text-white text-sm font-bold">
        {t('carahuacra.hero.badge')}
      </span>
      <h1 id="carahuacra-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight font-extrabold mb-4">{t('carahuacra.hero.title')}</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed mb-8">
        {t('carahuacra.hero.description')}
      </p>
      <div class="flex flex-wrap gap-4 text-sm font-bold">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined" aria-hidden="true">location_on</span> {t('carahuacra.hero.location')}
        </span>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined" aria-hidden="true">verified</span> {t('carahuacra.hero.status')}
        </span>
      </div>
    </div>
  </div>
</section>