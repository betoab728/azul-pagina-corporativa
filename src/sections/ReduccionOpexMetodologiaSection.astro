---
import { metodologiaItems } from '../data/reduccion-opex'
---

<section class="py-section-padding bg-surface-container-low" aria-labelledby="reduccion-opex-metodologia-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-8 md:mb-16">
      <h2 id="reduccion-opex-metodologia-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">¿Qué hacemos? (Metodología)</h2>
      <p class="text-lg text-on-surface-variant max-w-3xl mx-auto">Realizamos una evaluación integral de la gestión ambiental y de residuos, analizando cada nodo de la cadena operativa.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {metodologiaItems.map(item => (
        <div class="group bg-white p-8 rounded-xl border border-outline-variant hover:border-primary transition-all">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors text-primary">
            <span class="material-symbols-outlined" aria-hidden="true">{item.icon}</span>
          </div>
          <h3 class="text-sm font-bold text-on-surface mb-2">{item.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
