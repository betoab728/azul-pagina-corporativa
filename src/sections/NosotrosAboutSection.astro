---
import { checklistItems } from '../data/nosotros'

// TODO: Reemplazar con imagen real del cliente
const aboutImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDyMPTmtbM3Qlgu9ll56H3o6PjJ-cCRYEHMg6bOXd_w5wKS9_jKqCDC3Psej2AT0bYUgGAVQbM_gewSlCCYPkAksQa8pLE6zxIkuRg7zGBSD21xy5pK-QhSKsKSzjt15niOhEiYqGgk8NfQp-26x9ceADWhz3dJri6Zbx5bllhHqOVKfNUH9d-5yHN8UGQ-bDcVFtL_L13mgigyF_cIft0M4LsMQD0aHw7zQrY1QyhKfMXe70gm5YiQnFo_y_C6YLHfh73l4VEGaNmzVvo'
---

<section class="py-section-padding" aria-labelledby="nosotros-about-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">

      <div class="space-y-8">
        <h2 id="nosotros-about-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold">¿Qué hace Azul Sostenible y a quién ayuda?</h2>
        <p class="text-lg text-on-surface-variant leading-relaxed">
          Ayudamos a organizaciones del sector industrial, minero, salud y agroindustrial a cumplir la normativa ambiental, reducir riesgos legales y optimizar costos mediante una gestión técnica, trazable y sostenible de sus residuos.
        </p>
        <ul class="space-y-4">
          {checklistItems.map(item => (
            <li class="flex items-center gap-4">
              <div class="bg-secondary-container p-2 rounded-full flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-secondary-container text-[20px]" aria-hidden="true">{item.icon}</span>
              </div>
              <span class="text-on-surface font-semibold">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative group">
        <div class="absolute -inset-4 bg-primary/5 rounded-2xl group-hover:bg-primary/10 transition-colors" aria-hidden="true"></div>
        <img
          src={aboutImage}
          alt="Personal técnico de Azul Sostenible"
          class="relative w-full aspect-[4/3] object-cover rounded-2xl shadow-xl border border-outline-variant"
          loading="lazy"
          width="600"
          height="450"
        />
      </div>

    </div>
  </div>
</section>
