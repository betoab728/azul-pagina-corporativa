---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="morococha-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div>
          <h2 id="morococha-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-4">{t('morococha.que_hicimos.title')}</h2>
          <p class="text-on-surface-variant leading-relaxed">
            {t('morococha.que_hicimos.body')}
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-white" aria-hidden="true">description</span>
            </div>
            <div>
              <h4 class="font-bold text-sm text-on-surface mb-1">{t('morococha.que_hicimos.step1_title')}</h4>
              <p class="text-on-surface-variant">{t('morococha.que_hicimos.step1_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-white" aria-hidden="true">inventory</span>
            </div>
            <div>
              <h4 class="font-bold text-sm text-on-surface mb-1">{t('morococha.que_hicimos.step2_title')}</h4>
              <p class="text-on-surface-variant">{t('morococha.que_hicimos.step2_desc')}</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-white" aria-hidden="true">visibility</span>
            </div>
            <div>
              <h4 class="font-bold text-sm text-on-surface mb-1">{t('morococha.que_hicimos.step3_title')}</h4>
              <p class="text-on-surface-variant">{t('morococha.que_hicimos.step3_desc')}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 bg-secondary/10 rounded-xl blur-2xl"></div>
        <div class="relative p-2 rounded-xl overflow-hidden border border-outline-variant" style="background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px);">
          <img
            class="rounded-lg w-full h-[400px] object-cover"
            alt={t('morococha.que_hicimos.img_alt')}
            src="/morococha-hicimos.jpeg"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </div>
</section>
