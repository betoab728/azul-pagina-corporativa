---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="carahuacra-resumen-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <h2 id="carahuacra-resumen-heading" class="font-headline text-4xl font-extrabold text-primary mb-4">{t('carahuacra.resumen.title')}</h2>
      <p class="text-lg text-on-surface-variant max-w-2xl mx-auto">{t('carahuacra.resumen.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-8 border border-outline-variant rounded-2xl hover:border-secondary transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container-high rounded-lg flex items-center justify-center mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined" aria-hidden="true">rule</span>
        </div>
        <p class="font-headline text-4xl font-extrabold text-primary mb-2">100%</p>
        <p class="font-headline text-2xl font-bold mb-2">{t('carahuacra.resumen.stat1_label')}</p>
        <p class="text-on-surface-variant">{t('carahuacra.resumen.stat1_desc')}</p>
      </div>
      <div class="p-8 border border-outline-variant rounded-2xl hover:border-secondary transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container-high rounded-lg flex items-center justify-center mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined" aria-hidden="true">payments</span>
        </div>
        <p class="font-headline text-4xl font-extrabold text-primary mb-2">-35%</p>
        <p class="font-headline text-2xl font-bold mb-2">{t('carahuacra.resumen.stat2_label')}</p>
        <p class="text-on-surface-variant">{t('carahuacra.resumen.stat2_desc')}</p>
      </div>
      <div class="p-8 border border-outline-variant rounded-2xl hover:border-secondary transition-all duration-300 group">
        <div class="w-12 h-12 bg-surface-container-high rounded-lg flex items-center justify-center mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
          <span class="material-symbols-outlined" aria-hidden="true">recycling</span>
        </div>
        <p class="font-headline text-4xl font-extrabold text-primary mb-2">{t('carahuacra.resumen.stat3_value')}</p>
        <p class="font-headline text-2xl font-bold mb-2">{t('carahuacra.resumen.stat3_label')}</p>
        <p class="text-on-surface-variant">{t('carahuacra.resumen.stat3_desc')}</p>
      </div>
    </div>
  </div>
</section>
