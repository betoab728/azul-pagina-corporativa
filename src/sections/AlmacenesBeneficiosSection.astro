---
import { beneficiosAlmacenes } from '../data/almacenes-inteligentes'
---

<section class="bg-primary py-section-padding text-white" aria-labelledby="almacenes-beneficios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop text-center">
    <h2 id="almacenes-beneficios-heading" class="font-headline text-4xl md:text-5xl font-extrabold mb-8 md:mb-16">Impacto Directo en su <span class="text-secondary-fixed">Rentabilidad</span></h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
      {beneficiosAlmacenes.map(beneficio => (
        <div class="space-y-4 group">
          <div class="w-16 h-16 mx-auto rounded-full border border-white/20 flex items-center justify-center group-hover:bg-secondary transition-all">
            <span class="material-symbols-outlined" aria-hidden="true">{beneficio.icon}</span>
          </div>
          <div class="font-bold text-xl">{beneficio.title}</div>
        </div>
      ))}
    </div>
  </div>
</section>
