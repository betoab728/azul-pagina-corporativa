---
import type { SupportedLocale } from '../i18n/utils'
import QuoteForm from '../components/forms/QuoteForm.astro'

// TODO: Reemplazar con foto real del asesor
const advisorImage = 'https://plus.unsplash.com/premium_photo-1664297701028-3e9919a2574f?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'

const features = [
  { icon: 'schedule',      iconColor: 'secondary' as const, title: 'Respuesta rápida',    desc: 'Menos de 24 horas.' },
  { icon: 'verified_user', iconColor: 'primary'   as const, title: 'Asesoría experta',    desc: 'Soluciones a medida.' },
  { icon: 'description',   iconColor: 'secondary' as const, title: 'Propuesta a medida',  desc: 'Adaptada a tus necesidades.' },
  { icon: 'lock',          iconColor: 'primary'   as const, title: 'Confidencialidad',    desc: 'Información protegida.' },
]
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---

<section id="cotizacion" class="py-24 bg-white" aria-labelledby="quote-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col lg:flex-row gap-10 lg:gap-20">

      <!-- Columna izquierda: información -->
      <div class="w-full lg:w-1/2">
        <div class="inline-flex items-center gap-2 bg-secondary/10 text-secondary px-4 py-2 rounded-full mb-8">
          <span class="material-symbols-outlined text-sm" aria-hidden="true">eco</span>
          <span class="font-bold text-xs uppercase tracking-wider">COTIZACIÓN RÁPIDA</span>
        </div>

        <h2 id="quote-heading" class="font-headline text-[32px] md:text-5xl lg:text-6xl font-extrabold text-on-surface mb-8 leading-[1.1]">
          Cotiza tu proyecto<br />
          en <span class="text-secondary">2 minutos</span> 🍃
        </h2>

        <p class="text-lg text-on-surface-variant mb-12 max-w-lg leading-relaxed">
          Cuéntanos sobre tu proyecto y nuestro equipo de expertos te contactará con una propuesta personalizada.
        </p>

        <!-- Features -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
          {features.map(f => (
            <div class="flex items-center gap-4">
              <div class={`w-12 h-12 rounded-xl bg-surface-container flex items-center justify-center shadow-sm ${f.iconColor === 'primary' ? 'text-primary' : 'text-secondary'}`}>
                <span class="material-symbols-outlined" aria-hidden="true">{f.icon}</span>
              </div>
              <div>
                <h4 class="font-bold text-sm">{f.title}</h4>
                <p class="text-xs text-on-surface-variant">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Contacto personalizado -->
        <div class="bg-primary/5 p-8 rounded-3xl border border-primary/10 flex items-center gap-6">
          <img
            src={advisorImage}
            alt="Asesor de Azul Sostenible"
            class="w-20 h-20 rounded-2xl object-cover border-4 border-white shadow-md"
            loading="lazy"
            width="80"
            height="80"
          />
          <div>
            <h4 class="font-bold text-on-surface mb-1">¿Necesitas ayuda personalizada?</h4>
            <p class="text-sm text-on-surface-variant mb-2">Habla con un asesor especializado</p>
            <a href="tel:+51969123456" class="flex items-center gap-2 text-primary font-extrabold text-lg">
              <span class="material-symbols-outlined" aria-hidden="true">call</span>
              +51 940 857666
            </a>
          </div>
        </div>
      </div>

      <!-- Columna derecha: formulario -->
      <div class="w-full lg:w-1/2">
        <QuoteForm />
      </div>

    </div>
  </div>
</section>