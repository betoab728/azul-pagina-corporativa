---
import { beneficios, empresaStats } from '../data/caracterizacion'
---

<section class="py-section-padding bg-on-surface text-white" aria-labelledby="beneficios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
    <div class="space-y-8">
      <h2 id="beneficios-heading" class="font-headline text-4xl md:text-5xl font-extrabold">¿Qué gana tu empresa?</h2>
      <ul class="space-y-6" aria-label="Beneficios del servicio">
        {beneficios.map(item => (
          <li class="flex gap-4 items-start group">
            <div class="mt-1 bg-secondary text-white rounded-full p-1 shrink-0 group-hover:rotate-12 transition-transform">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{item.icon}</span>
            </div>
            <div>
              <span class="block font-bold text-white text-lg">{item.title}</span>
              <p class="text-surface-variant">{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="space-y-4 pt-12">
        {empresaStats.filter((_, i) => i % 2 === 0).map(stat => (
          <div class="bg-white/10 p-6 rounded-xl border border-outline/30 text-center">
            <div class={`text-4xl font-extrabold mb-2 ${stat.highlight ? 'text-secondary' : 'text-primary-fixed-dim'}`}>
              {stat.value}
            </div>
            <div class="text-sm text-surface-variant font-semibold">{stat.label}</div>
          </div>
        ))}
      </div>
      <div class="space-y-4">
        {empresaStats.filter((_, i) => i % 2 === 1).map(stat => (
          <div class="bg-white/10 p-6 rounded-xl border border-outline/30 text-center">
            <div class={`text-4xl font-extrabold mb-2 ${stat.highlight ? 'text-secondary' : 'text-primary-fixed-dim'}`}>
              {stat.value}
            </div>
            <div class="text-sm text-surface-variant font-semibold">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
