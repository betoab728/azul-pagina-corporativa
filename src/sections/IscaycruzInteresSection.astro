---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="iscaycruz-interes-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="iscaycruz-interes-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('iscaycruz.interes.title')}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="p-8 rounded-xl flex flex-col items-center text-center group border border-outline-variant bg-white hover:border-primary transition-all duration-300" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px);">
        <div class="w-16 h-16 bg-primary-fixed flex items-center justify-center rounded-full text-primary mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined text-[32px]" aria-hidden="true">biotech</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-4">{t('iscaycruz.interes.card1_title')}</h3>
        <p class="text-sm text-on-surface-variant mb-6">{t('iscaycruz.interes.card1_desc')}</p>
        <a href="/servicios/caracterizacion-de-residuos" class="text-primary font-bold hover:underline flex items-center gap-2">{t('btn.more')} <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
      </div>
      <div class="p-8 rounded-xl flex flex-col items-center text-center group border border-outline-variant bg-white hover:border-primary transition-all duration-300" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px);">
        <div class="w-16 h-16 bg-primary-fixed flex items-center justify-center rounded-full text-primary mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined text-[32px]" aria-hidden="true">gavel</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-4">{t('iscaycruz.interes.card2_title')}</h3>
        <p class="text-sm text-on-surface-variant mb-6">{t('iscaycruz.interes.card2_desc')}</p>
        <a href="/servicios/reclasificacion-de-residuos" class="text-primary font-bold hover:underline flex items-center gap-2">{t('btn.more')} <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
      </div>
      <div class="p-8 rounded-xl flex flex-col items-center text-center group border border-outline-variant bg-white hover:border-primary transition-all duration-300" style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px);">
        <div class="w-16 h-16 bg-primary-fixed flex items-center justify-center rounded-full text-primary mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined text-[32px]" aria-hidden="true">eco</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-4">{t('iscaycruz.interes.card3_title')}</h3>
        <p class="text-sm text-on-surface-variant mb-6">{t('iscaycruz.interes.card3_desc')}</p>
        <a href="/servicios/reduccion-del-opex" class="text-primary font-bold hover:underline flex items-center gap-2">{t('btn.more')} <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
      </div>
    </div>
  </div>
</section>
