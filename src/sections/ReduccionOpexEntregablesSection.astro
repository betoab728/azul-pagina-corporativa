---
import { entregables } from '../data/reduccion-opex'
---

<section class="py-section-padding bg-white" aria-labelledby="reduccion-opex-entregables-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="reduccion-opex-entregables-heading" class="font-headline text-4xl md:text-5xl text-primary text-center font-extrabold mb-16">Entregables (¿Qué recibe su empresa?)</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {entregables.map(item => (
        <div class="bg-surface p-8 rounded-xl border border-outline-variant flex flex-col h-full">
          <div class="text-primary font-extrabold text-4xl mb-4">{item.number}</div>
          <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">{item.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
