---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="carahuacra-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 id="carahuacra-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('carahuacra.que_hicimos.title')}</h2>
        <div class="space-y-6 text-on-surface-variant">
          <p class="text-lg">
            {t('carahuacra.que_hicimos.intro')}
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-secondary mt-1 shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('carahuacra.que_hicimos.item1')}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-secondary mt-1 shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('carahuacra.que_hicimos.item2')}</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-secondary mt-1 shrink-0" aria-hidden="true">check_circle</span>
              <span>{t('carahuacra.que_hicimos.item3')}</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="relative">
        <div class="rounded-xl overflow-hidden shadow-2xl">
          <img
            class="w-full aspect-square object-cover"
            alt={t('carahuacra.que_hicimos.img_alt')}
            src="/carahuacra-hicimos.jpeg"
            loading="lazy"
            width="600"
            height="600"
          />
        </div>
        <div class="absolute -bottom-8 -left-8 p-6 rounded-xl max-w-xs border border-outline-variant/50 shadow-lg" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px);">
          <p class="text-secondary font-headline text-2xl font-bold mb-2">{t('carahuacra.que_hicimos.card_title')}</p>
          <p class="text-on-surface-variant text-sm">{t('carahuacra.que_hicimos.card_desc')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
