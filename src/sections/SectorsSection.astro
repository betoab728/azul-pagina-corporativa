---
import type { SupportedLocale } from '../i18n/utils'
import SectorCard from '../components/blocks/SectorCard.astro'
import { getSectors } from '../data/sectors'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const sectors = getSectors(lang)
---

<section id="sectores" class="py-20 bg-white" aria-labelledby="sectors-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold text-sm uppercase tracking-widest">SECTORES QUE ATENDEMOS</span>
      <h2 id="sectors-heading" class="font-headline text-4xl md:text-5xl font-extrabold mt-4 mb-4">
        Acompañamos a empresas de distintos sectores
      </h2>
      <p class="text-on-surface-variant text-lg max-w-2xl mx-auto">
        Adaptamos nuestras soluciones a los desafíos ambientales de cada industria.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {sectors.map(sector => (
        <SectorCard {...sector} />
      ))}
    </div>
  </div>
</section>