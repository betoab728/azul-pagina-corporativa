---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuBo_q1o9cG3kjCasuPUmZpWkuTMPRjSPKmGtxs10TJrh3FZTCBR4fYA5SkQfx3Dd-xHQhYQK2PLzQ45XvAWaQuTcMRZFZqpMD374kmR5gVJRO2TI3HC94asygqjD0RI21wHsaG0d3KEFqkAI-p8KeysvOgJbftlMz5qWTLO5THKfg1YI6R32mWqg8A6e5aQAro4VEZomE7LEKQafsVSmABproaQLVcF1NJWDvxhqY9N0n7F8EwqUsJghYWsNV8hEXythUpeUmDf3-QO'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="americana-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="americana-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/90 to-primary/40"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">
        {t('projects.badge')}
      </span>
      <h1 id="americana-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-4">{t('americana.hero.title')}</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed">{t('americana.hero.subtitle')}</p>
    </div>
  </div>
</section>