---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="americana-que-hicimos-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
      <div class="lg:col-span-7">
        <h2 id="americana-que-hicimos-heading" class="font-headline text-4xl font-extrabold text-primary mb-8">{t('americana.que_hicimos.title')}</h2>
        <p class="font-body text-lg text-on-surface-variant mb-12 leading-relaxed">
          {t('americana.que_hicimos.body')}
        </p>
        <div class="grid grid-cols-2 gap-6">
          <div class="p-6 bg-surface-container-low rounded-xl flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined" aria-hidden="true">science</span>
            </div>
            <div>
              <h4 class="font-bold text-sm text-primary mb-1">{t('americana.que_hicimos.card1_title')}</h4>
              <p class="text-sm text-on-surface-variant/70">{t('americana.que_hicimos.card1_desc')}</p>
            </div>
          </div>
          <div class="p-6 bg-surface-container-low rounded-xl flex items-start gap-4">
            <div class="w-12 h-12 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined" aria-hidden="true">inventory_2</span>
            </div>
            <div>
              <h4 class="font-bold text-sm text-primary mb-1">{t('americana.que_hicimos.card2_title')}</h4>
              <p class="text-sm text-on-surface-variant/70">{t('americana.que_hicimos.card2_desc')}</p>
            </div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-5 relative group">
        <div class="absolute inset-0 bg-secondary/10 rounded-3xl translate-x-4 translate-y-4 -z-10 transition-transform group-hover:translate-x-2 group-hover:translate-y-2"></div>
        <img
          class="w-full h-[500px] object-cover rounded-3xl shadow-xl"
          alt={t('americana.que_hicimos.img_alt')}
          src="/americana-hicimos.jpeg"
          loading="lazy"
          width="600"
          height="500"
        />
      </div>
    </div>
  </div>
</section>
