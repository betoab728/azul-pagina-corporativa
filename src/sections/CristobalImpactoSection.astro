---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20" aria-labelledby="cristobal-impacto-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="cristobal-impacto-heading" class="font-headline text-4xl font-extrabold text-primary text-center mb-16">{t('cristobal.impacto.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2 bg-white border border-outline-variant rounded-2xl p-10 flex flex-col justify-between hover:border-primary transition-all shadow-sm">
        <div>
          <span class="text-secondary font-bold text-sm uppercase tracking-widest mb-4 block">{t('cristobal.impacto.card1_badge')}</span>
          <h3 class="font-headline text-4xl font-extrabold mb-4">{t('cristobal.impacto.card1_title')}</h3>
          <p class="text-on-surface-variant text-lg">{t('cristobal.impacto.card1_desc')}</p>
        </div>
        <div class="flex items-end justify-between border-t border-outline-variant pt-6 mt-8">
          <div class="text-primary font-headline text-4xl font-extrabold">-35% <span class="text-sm text-on-surface-variant font-normal">{t('cristobal.impacto.card1_stat')}</span></div>
          <span class="material-symbols-outlined text-4xl text-secondary" aria-hidden="true">trending_down</span>
        </div>
      </div>
      <div class="bg-secondary-container rounded-2xl p-10 flex flex-col justify-center text-on-secondary-container">
        <span class="material-symbols-outlined text-5xl mb-6" aria-hidden="true">balance</span>
        <h3 class="font-headline text-2xl font-bold mb-4">{t('cristobal.impacto.card2_title')}</h3>
        <p class="text-sm leading-relaxed">{t('cristobal.impacto.card2_desc')}</p>
      </div>
      <div class="md:col-span-3 bg-white border border-outline-variant rounded-2xl p-8 flex items-center justify-between hover:shadow-md transition-all">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 bg-surface-container-low rounded-full flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-3xl" aria-hidden="true">recycling</span>
          </div>
          <div>
            <h4 class="font-headline text-2xl font-bold">{t('cristobal.impacto.card3_title')}</h4>
            <p class="text-on-surface-variant">{t('cristobal.impacto.card3_desc')}</p>
          </div>
        </div>
        <span class="material-symbols-outlined text-primary hidden md:block" aria-hidden="true">arrow_forward</span>
      </div>
    </div>
  </div>
</section>
