---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getAlcanceItems } from '../data/tarifa-plana'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const alcanceItems = getAlcanceItems(lang)
---

<section id="tarifa-plana-alcance" class="py-section-padding bg-surface" aria-labelledby="tarifa-plana-alcance-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-16 gap-8">
      <div class="max-w-xl">
        <h2 id="tarifa-plana-alcance-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-4">{t('tarifa_plana.alcance.title')}</h2>
        <p class="text-lg text-on-surface-variant">{t('tarifa_plana.alcance.subtitle')}</p>
      </div>
      <div class="text-sm font-bold text-secondary flex items-center gap-2 shrink-0">
        <span class="material-symbols-outlined" aria-hidden="true">checklist</span>
        {t('tarifa_plana.alcance.list_label')}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-outline-variant border border-outline-variant rounded-2xl overflow-hidden shadow-sm">
      {alcanceItems.map(item => (
        <div class="bg-white p-8 flex gap-4 hover:bg-surface-container-low transition-colors">
          <span class="material-symbols-outlined text-primary shrink-0 mt-0.5" aria-hidden="true">{item.icon}</span>
          <div>
            <h3 class="font-headline text-lg font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>