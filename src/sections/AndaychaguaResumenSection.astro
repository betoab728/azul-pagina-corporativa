---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-white overflow-hidden relative" aria-labelledby="andaychagua-resumen-heading">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-secondary"></div>
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop text-center">
    <h2 id="andaychagua-resumen-heading" class="font-headline text-4xl font-extrabold text-primary mb-12">{t('andaychagua.resumen.title')}</h2>
    <div class="max-w-4xl mx-auto">
      <div class="bg-background p-12 rounded-3xl border border-outline-variant relative">
        <span class="material-symbols-outlined text-secondary text-[64px] mb-8 block" aria-hidden="true" style="font-variation-settings: 'FILL' 1;">military_tech</span>
        <p class="font-headline text-2xl md:text-3xl font-bold text-on-surface mb-8 leading-snug">
          {t('andaychagua.resumen.body')} <span class="text-secondary">{t('andaychagua.resumen.body_highlight')}</span>
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
          <div class="flex gap-4">
            <span class="material-symbols-outlined text-secondary shrink-0" aria-hidden="true">check_circle</span>
            <p class="text-on-surface-variant">{t('andaychagua.resumen.benefit_1')}</p>
          </div>
          <div class="flex gap-4">
            <span class="material-symbols-outlined text-secondary shrink-0" aria-hidden="true">check_circle</span>
            <p class="text-on-surface-variant">{t('andaychagua.resumen.benefit_2')}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
