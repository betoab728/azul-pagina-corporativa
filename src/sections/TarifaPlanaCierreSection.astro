---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding bg-primary text-white text-center relative overflow-hidden" aria-labelledby="tarifa-plana-cierre-heading">
  <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-secondary rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-tertiary rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <h2 id="tarifa-plana-cierre-heading" class="font-headline text-[32px] md:text-5xl font-extrabold mb-8">{t('tarifa_plana.cierre.title')}</h2>
    <p class="text-lg mb-12 text-on-primary-container leading-relaxed">
      {t('tarifa_plana.cierre.subtitle')}
    </p>
    <a
      href="https://wa.me/51936602578"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 bg-secondary text-white font-bold px-8 md:px-12 py-3 md:py-5 rounded-full hover:scale-105 transition-transform shadow-2xl"
    >
      {t('tarifa_plana.cierre.cta')}
      <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
    </a>
  </div>
</section>
