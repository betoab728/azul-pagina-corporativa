---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = '/tarifahero.jpeg'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="tarifa-plana-hero" class="relative min-h-[85vh] flex items-center pt-20 overflow-hidden" aria-labelledby="tarifa-plana-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(247, 249, 251, 0.95) 0%, rgba(247, 249, 251, 0.95) 30%, rgba(247, 249, 251, 0.2) 100%);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-secondary-container text-on-secondary-container font-bold text-sm mb-6">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">verified</span>
        {t('tarifa_plana.hero.badge')}
      </div>

      <h1 id="tarifa-plana-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-primary mb-6 font-extrabold">
        {t('tarifa_plana.hero.title')}
      </h1>

      <p class="font-body text-lg text-on-surface-variant mb-10 max-w-xl leading-relaxed">
        {t('tarifa_plana.hero.subtitle')}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="https://wa.me/51936602578"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center bg-secondary text-white font-bold px-6 md:px-8 py-3 md:py-4 rounded-full hover:scale-[1.02] transition-transform shadow-lg"
        >
          {t('tarifa_plana.hero.cta_primary')}
        </a>
        <a
          href="#tarifa-plana-alcance"
          class="inline-flex items-center bg-surface-container-low text-primary border border-outline-variant font-bold px-6 md:px-8 py-3 md:py-4 rounded-full hover:bg-surface-container-high transition-colors"
        >
          {t('tarifa_plana.hero.cta_secondary')}
        </a>
      </div>
    </div>
  </div>
</section>