---
import type { SupportedLocale } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuD9Fh_B8Xu9CuTIR-wNjyJGE_F7GSPNCf9v2npia-Oa0pLUyEAsNCno7AblvUCKrwjBJQsmPvn2Ndv2-3ebFY9XuQjOyu2ECI8gJv7f0tiR5UML3RyvIGjpTRqpxw3pegP-Xe2NAghdHxaQo4T2NzyoednGLp80_OxrcBFpdyduvJv3UNclEtqsYkA9gJEnMW55Ffgw0J7E-x5YD1ghispoIym8GkLK3ZXHk2U1TU5qsZIRvx0teGaFPeEt32O2NW6GWlxWM68uTFIQ'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---

<section id="chungar-hero" class="relative min-h-[400px] md:h-[614px] flex items-center overflow-hidden" aria-labelledby="chungar-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover brightness-50"
      loading="eager"
      width="1920"
      height="614"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-margin-desktop w-full">
    <div class="max-w-3xl">
      <span class="inline-block px-4 py-1 mb-6 rounded-full bg-secondary-container text-on-secondary-container text-sm font-bold">
        PROYECTO DE ÉXITO
      </span>
      <h1 id="chungar-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-white font-extrabold mb-6">UM. CHUNGAR - Casos de éxito</h1>
      <p class="font-body text-lg text-white/90 leading-relaxed max-w-xl">Optimizando la gestión de residuos en la Unidad Minera Animón mediante ingeniería ambiental de alta precisión.</p>
    </div>
  </div>
</section>