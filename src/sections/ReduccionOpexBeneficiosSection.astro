---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
import { getBeneficiosOPEX } from '../data/reduccion-opex'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
const beneficiosOPEX = getBeneficiosOPEX(lang)
---

<section class="py-section-padding bg-primary text-white" aria-labelledby="reduccion-opex-beneficios-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="reduccion-opex-beneficios-heading" class="font-headline text-4xl md:text-5xl font-extrabold mb-8 md:mb-16 text-center">{t('reduccion_opex.beneficios.title')}</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-y-16 gap-x-6">
      {beneficiosOPEX.map(beneficio => (
        <div class="text-center">
          <span class="material-symbols-outlined text-secondary-fixed text-5xl mb-4 block" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{beneficio.icon}</span>
          <h4 class="font-headline text-2xl font-bold mb-2">{beneficio.title}</h4>
          <p class="opacity-80 text-sm leading-relaxed">{beneficio.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
