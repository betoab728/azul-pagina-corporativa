---
import type { SupportedLocale } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
---
<section class="bg-primary py-24 relative overflow-hidden">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
  </div>
  <div class="relative z-10 max-w-[800px] mx-auto px-6 md:px-margin-desktop text-center text-white">
    <h2 class="font-headline text-4xl md:text-5xl font-extrabold mb-6">Optimiza tu gestión ambiental hoy</h2>
    <p class="font-body text-lg mb-10 text-white/80">Brindamos el respaldo técnico necesario para que tu empresa sea un referente en sostenibilidad industrial.</p>
    <a
      href="/contacto"
      class="inline-block bg-secondary text-white px-10 py-4 rounded-full font-bold text-lg hover:scale-105 active:scale-95 transition-all shadow-xl"
    >
      Iniciar consulta técnica
    </a>
  </div>
</section>
