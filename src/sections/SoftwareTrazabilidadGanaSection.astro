---
import { beneficios } from '../data/software-trazabilidad'
---

<section class="py-section-padding bg-surface-container-lowest" aria-labelledby="software-trazabilidad-gana-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
      <h2 id="software-trazabilidad-gana-heading" class="font-headline text-4xl md:text-5xl font-extrabold">¿QUÉ GANA TU EMPRESA?</h2>
      <p class="text-lg text-on-surface-variant">Optimizamos tu operación ambiental mediante tecnología de vanguardia y procesos simplificados.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-6 lg:grid-cols-12 gap-6">
      {beneficios.map(beneficio => (
        beneficio.variant === 'white' ? (
          <article class={`${beneficio.span} bg-white p-8 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between`}>
            <div>
              <span class="material-symbols-outlined text-[40px] text-primary mb-6 block" aria-hidden="true">{beneficio.icon}</span>
              <h3 class="text-2xl font-bold mb-3">{beneficio.title}</h3>
              <p class="text-on-surface-variant">{beneficio.description}</p>
            </div>
          </article>
        ) : beneficio.variant === 'dark' ? (
          <article class={`${beneficio.span} bg-primary text-white p-8 rounded-xl shadow-xl flex flex-col justify-center`}>
            <div class="flex items-center gap-4 mb-6">
              <span class="material-symbols-outlined text-[48px] text-secondary-fixed flex-shrink-0" aria-hidden="true">{beneficio.icon}</span>
              <h3 class="text-2xl font-bold">{beneficio.title}</h3>
            </div>
            <p class="text-white/80">{beneficio.description}</p>
          </article>
        ) : beneficio.variant === 'white-box' ? (
          <article class={`${beneficio.span} bg-white p-8 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow flex items-start gap-6`}>
            <div class="p-4 bg-surface-container rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-primary text-[32px]" aria-hidden="true">{beneficio.icon}</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold mb-2">{beneficio.title}</h3>
              <p class="text-on-surface-variant">{beneficio.description}</p>
            </div>
          </article>
        ) : (
          <article class={`${beneficio.span} bg-secondary-container text-on-secondary-container p-8 rounded-xl shadow-sm hover:shadow-md transition-shadow flex items-start gap-6`}>
            <div class="p-4 bg-white/50 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-secondary text-[32px]" aria-hidden="true">{beneficio.icon}</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold mb-2">{beneficio.title}</h3>
              <p class="opacity-90">{beneficio.description}</p>
            </div>
          </article>
        )
      ))}
    </div>
  </div>
</section>
