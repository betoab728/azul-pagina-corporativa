---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
const heroImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuDpOzNYKVkxRh9VVWkE-QpPBf9GC1-8M6WegAhMOWp8uUdBOaBlts79V4CuFeQdDgfOnFt_SNepjFPNOCClW9cobu3quUClyDx6uL-9pfO4GOOBB3lenIDAsKqkhsPxaNL-YvTfW-OjsVScaFv7_-mNr-FInMYAL0Sfj3ur7_66YNCzJXi2lXjXV1bVWeUeKHetBx043S8iTThVBNjxS-f-xbdUfK2Lh22Pzm9YyC2tuII5g9HPAbSPIqKEqm5m7WnI-qZOwGI5bBLf'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---

<section id="reduccion-opex-hero" class="relative h-[85vh] min-h-[600px] flex items-center overflow-hidden" aria-labelledby="reduccion-opex-hero-heading">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0 bg-primary/60 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-margin-desktop text-white">
    <span class="inline-block px-4 py-1 bg-secondary-container text-on-secondary-container rounded-full text-sm font-bold mb-6">{t('reduccion_opex.hero.badge')}</span>
    <h1 id="reduccion-opex-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight mb-4 font-extrabold max-w-3xl">{t('reduccion_opex.hero.title')}</h1>
    <p class="font-headline text-2xl font-bold text-primary-fixed mb-6">{t('reduccion_opex.hero.tagline')}</p>
    <p class="font-body text-lg max-w-2xl opacity-90 leading-relaxed">{t('reduccion_opex.hero.subtitle')}</p>
  </div>
</section>
