---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-section-padding" aria-labelledby="nosotros-compliance-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="bg-primary-container/10 p-6 md:p-12 rounded-[32px] border border-primary/10 flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1">
        <h2 id="nosotros-compliance-heading" class="font-headline text-4xl md:text-5xl text-primary font-extrabold mb-6">{t('nosotros.compliance.title')}</h2>
        <p class="text-lg text-on-surface-variant leading-relaxed">
          {t('nosotros.compliance.body')}
        </p>
      </div>
      <div class="shrink-0">
        <span class="material-symbols-outlined text-primary text-[120px] opacity-20" aria-hidden="true">gavel</span>
      </div>
    </div>
  </div>
</section>
