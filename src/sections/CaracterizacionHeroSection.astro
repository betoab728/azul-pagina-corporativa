---
// TODO: Reemplazar con imagen real del cliente
const heroBgImage = 'https://lh3.googleusercontent.com/aida/ADBb0ug4IVJVRSjTT3aKeyoIKznbkwyTsprwW7W0ABRLeHKPcplUY0RQf3ZiNiw6P0qFrEt37FQdRwH-UOIKqsInjWhjQBUOZ7FOzgccQY_VMxon6gMufPDIhHTchOaKmRhEASZKSxWhD9SQNzSCUA1aCjIzkopuPWwsJch2DbkzNZY7WXThRVxteaxqY5nSsD-EpQhnH2eCv22rwG0jU-RwFi1N4LYmUDNJc3YhsZJsneSh2zajaep9IN8Fsk6G'

const heroFgImage = heroBgImage
---

<section
  id="caracterizacion-hero"
  class="pt-32 pb-section-padding md:px-margin-desktop px-6 relative overflow-hidden"
  style="background: linear-gradient(rgba(247, 249, 251, 0.7), rgba(247, 249, 251, 0.95)), url('${heroBgImage}'); background-size: cover; background-position: center;"
  aria-labelledby="caracterizacion-hero-heading"
>
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div class="space-y-8">
      <h1 id="caracterizacion-hero-heading" class="font-headline text-[32px] md:text-[40px] lg:text-[48px] leading-tight text-primary font-extrabold">
        Caracterización de residuos sólidos
      </h1>
      <p class="font-body text-lg text-on-surface-variant max-w-lg leading-relaxed">
        Reducimos tu costo de disposición final entre <span class="font-bold text-secondary">30% y 80%</span> mediante reclasificación técnica con respaldo normativo.
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href="#cotizacion"
          class="inline-flex items-center gap-3 bg-secondary text-white font-bold px-8 py-4 rounded-full hover:bg-secondary/90 hover:shadow-lg transition-all active:scale-95 group"
        >
          Quiero mi caracterización
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
        </a>
        <div class="flex items-center gap-2 text-primary font-bold">
          <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">verified</span>
          <span class="text-sm">Respaldo Normativo</span>
        </div>
      </div>
    </div>

    <div class="relative hidden md:block">
      <div class="absolute -inset-4 bg-primary/5 rounded-3xl blur-2xl" aria-hidden="true"></div>
      <img
        src={heroFgImage}
        alt="Planta industrial con equipamiento moderno de gestión de residuos"
        class="relative rounded-xl border border-outline-variant shadow-xl object-cover h-[500px] w-full"
        loading="eager"
        width="600"
        height="500"
      />
    </div>
  </div>
</section>
