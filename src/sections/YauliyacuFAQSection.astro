---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-surface-container-lowest" aria-labelledby="yauliyacu-faq-heading">
  <div class="max-w-3xl mx-auto px-6">
    <h2 id="yauliyacu-faq-heading" class="font-headline text-4xl font-extrabold text-primary mb-12 text-center">{t('about.faq')}</h2>
    <div class="space-y-4">
      <details class="group border border-outline-variant rounded-xl overflow-hidden bg-white" open>
        <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors list-none">
          <h4 class="font-headline text-lg font-bold text-on-surface">{t('yauliyacu.faq.q1')}</h4>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/30 pt-6">
          {t('yauliyacu.faq.a1')}
        </div>
      </details>
      <details class="group border border-outline-variant rounded-xl overflow-hidden bg-white">
        <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors list-none">
          <h4 class="font-headline text-lg font-bold text-on-surface">{t('yauliyacu.faq.q2')}</h4>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/30 pt-6">
          {t('yauliyacu.faq.a2')}
        </div>
      </details>
      <details class="group border border-outline-variant rounded-xl overflow-hidden bg-white">
        <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors list-none">
          <h4 class="font-headline text-lg font-bold text-on-surface">{t('yauliyacu.faq.q3')}</h4>
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0" aria-hidden="true">expand_more</span>
        </summary>
        <div class="px-6 pb-6 text-on-surface-variant border-t border-outline-variant/30 pt-6">
          {t('yauliyacu.faq.a3')}
        </div>
      </details>
    </div>
  </div>
</section>
