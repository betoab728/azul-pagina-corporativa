---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-white" aria-labelledby="andaychagua-interes-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <h2 id="andaychagua-interes-heading" class="font-headline text-4xl font-extrabold text-primary mb-12">{t('andaychagua.interes.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/servicios/caracterizacion-de-residuos" class="group">
        <div class="rounded-xl overflow-hidden mb-6 aspect-video">
          <img
            alt={t('andaychagua.interes.card1_img_alt')}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            width="400"
            height="225"
            src="/interes1-andachagua.jpeg"
          />
        </div>
        <h4 class="font-headline text-xl font-bold text-primary mb-2 group-hover:text-secondary transition-colors">{t('andaychagua.interes.card1_title')}</h4>
        <p class="text-on-surface-variant">{t('andaychagua.interes.card1_desc')}</p>
      </a>
      <a href="/servicios/reclasificacion-de-residuos" class="group">
        <div class="rounded-xl overflow-hidden mb-6 aspect-video">
          <img
            alt={t('andaychagua.interes.card2_img_alt')}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            width="400"
            height="225"
            src="/interes2-andachagua.jpeg"
          />
        </div>
        <h4 class="font-headline text-xl font-bold text-primary mb-2 group-hover:text-secondary transition-colors">{t('andaychagua.interes.card2_title')}</h4>
        <p class="text-on-surface-variant">{t('andaychagua.interes.card2_desc')}</p>
      </a>
      <a href="/servicios/software-trazabilidad" class="group">
        <div class="rounded-xl overflow-hidden mb-6 aspect-video">
          <img
            alt={t('andaychagua.interes.card3_img_alt')}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            width="400"
            height="225"
            src="/interes3-andachagua.jpeg"
          />
        </div>
        <h4 class="font-headline text-xl font-bold text-primary mb-2 group-hover:text-secondary transition-colors">{t('andaychagua.interes.card3_title')}</h4>
        <p class="text-on-surface-variant">{t('andaychagua.interes.card3_desc')}</p>
      </a>
    </div>
  </div>
</section>
