---
import type { SupportedLocale } from '../i18n/utils'
import { useTranslations } from '../i18n/utils'
interface Props { lang?: SupportedLocale }
const { lang = 'es' } = Astro.props
const t = useTranslations(lang)
---
<section class="py-20 bg-white" aria-labelledby="aliados-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="mb-16">
      <h2 id="aliados-heading" class="font-headline text-4xl md:text-5xl font-extrabold text-primary mb-4">{t('recursos.aliados.title')}</h2>
      <p class="text-lg text-on-surface-variant max-w-2xl">{t('recursos.aliados.subtitle')}</p>
    </div>

    <div class="space-y-8">
      <!-- Wastefy -->
      <div class="grid grid-cols-1 md:grid-cols-2 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow" style="background-color: #38b000;">
        <div class="p-8 md:p-12 flex flex-col justify-center order-2 md:order-1 h-64 md:h-[450px]">
          <h3 class="font-headline text-3xl md:text-4xl font-extrabold text-white mb-4">{t('recursos.aliados.wastefy_title')}</h3>
          <p class="text-white/90 text-lg leading-relaxed mb-4">
            {t('recursos.aliados.wastefy_subtitle')}
          </p>
          <p class="text-white/80 leading-relaxed mb-8">
            {t('recursos.aliados.wastefy_body')}
          </p>
          <div>
            <a href="#" class="inline-flex items-center gap-2 bg-white text-[#38b000] font-bold px-8 py-3 rounded-full hover:bg-gray-100 transition-colors">
              {t('recursos.aliados.wastefy_cta')}
              <span class="material-symbols-outlined text-sm" aria-hidden="true">download</span>
            </a>
          </div>
        </div>
        <div class="h-64 md:h-[500px] order-1 md:order-2">
          <img
            src="/1-wastefy-app.png"
            alt="Wastefy App"
            class="w-full h-full object-cover"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>

      <!-- AndesLab -->
      <div class="grid grid-cols-1 md:grid-cols-2 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow" style="background-color: #4f46e5;">
        <div class="p-8 md:p-12 flex flex-col justify-center order-2 md:order-1 h-64 md:h-[450px]">
          <img
            src="/andeslablogo.png"
            alt="AndesLab"
            class="h-20 w-auto object-contain mb-6"
            loading="lazy"
            width="160"
            height="40"
          />
          <p class="text-white/90 leading-relaxed">
            {t('recursos.aliados.andeslab_body')}
          </p>
        </div>
        <div class="h-64 md:h-[450px] order-1 md:order-2">
          <img
            src="/2-andeslab.jpg"
            alt="AndesLab"
            class="w-full h-full object-cover"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>

      <!-- Banco de Residuos del Perú -->
      <div class="grid grid-cols-1 md:grid-cols-2 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow" style="background-color: #7dd3c7;">
        <div class="p-8 md:p-12 flex flex-col justify-center order-2 md:order-1 h-64 md:h-[400px]">
          <img
            src="/bancologo.png"
            alt="Banco de Residuos del Perú"
            class="h-20 w-auto object-contain mb-6"
            loading="lazy"
            width="160"
            height="40"
          />
          <p class="text-on-surface leading-relaxed">
            {t('recursos.aliados.banco_body')}
          </p>
        </div>
        <div class="h-64 md:h-[400px] order-1 md:order-2">
          <img
            src="/bancores2.jpeg"
            alt="Banco de Residuos del Perú"
            class="w-full h-full object-cover"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </div>
</section>
