---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/navigation/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description: string
  image?: string
  canonical?: string
}

const props = Astro.props
---

<BaseLayout {...props}>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
