---
import { getLang, getAlternates, getBasePath } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import TarifaPlanaHeroSection from '../../sections/TarifaPlanaHeroSection.astro'
import TarifaPlanaDefinicionSection from '../../sections/TarifaPlanaDefinicionSection.astro'
import TarifaPlanaIncluyeSection from '../../sections/TarifaPlanaIncluyeSection.astro'
import TarifaPlanaBeneficiosSection from '../../sections/TarifaPlanaBeneficiosSection.astro'
import TarifaPlanaIngenieriaSection from '../../sections/TarifaPlanaIngenieriaSection.astro'
import TarifaPlanaAlcanceSection from '../../sections/TarifaPlanaAlcanceSection.astro'
import TarifaPlanaCierreSection from '../../sections/TarifaPlanaCierreSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="Tarifa Plana Ambiental | Azul Sostenible"
  description="Gestión ambiental integral con tarifa fija anual. Todo incluido: recolección, saneamiento, capacitación y cumplimiento normativo garantizado por 12 meses."
>
  <TarifaPlanaHeroSection lang={lang} />
  <TarifaPlanaDefinicionSection lang={lang} />
  <TarifaPlanaIncluyeSection lang={lang} />
  <TarifaPlanaBeneficiosSection lang={lang} />
  <TarifaPlanaIngenieriaSection lang={lang} />
  <TarifaPlanaAlcanceSection lang={lang} />
  <TarifaPlanaCierreSection lang={lang} />
</PageLayout>
