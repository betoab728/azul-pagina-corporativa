const content = contentByLocale[lang] ?? contentByLocale.es
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title={content.title + ' | Azul Sostenible'}
  description="Términos y condiciones de uso del sitio web de Azul Sostenible S.A.C."
>
  <main class="py-section-padding bg-surface">
    <div class="max-w-3xl mx-auto px-6 md:px-margin-desktop">
      <div class="mb-12 md:mb-16">
        <h1 class="font-headline text-3xl md:text-4xl lg:text-5xl text-primary font-extrabold mb-3">
          {content.title}
        </h1>
        <p class="text-on-surface-variant text-sm">{content.update}</p>
      </div>

      <p class="text-on-surface-variant leading-relaxed mb-10">
        {content.intro}
      </p>

      <div class="space-y-10">
        {content.sections.map(section => (
          <section>
            <h2 class="font-headline text-xl md:text-2xl text-primary font-bold mb-4">
              {section.heading}
            </h2>

            {section.intro && (
              <p class="text-on-surface-variant leading-relaxed mb-4">{section.intro}</p>
            )}

            {section.body && (
              <p class="text-on-surface-variant leading-relaxed">
                {section.body}
                {section.link && (
                  <a href={section.link.href} class="text-primary font-semibold hover:underline">{section.link.text}</a>
                )}
              </p>
            )}

            {section.list && (
              <ul class="list-disc pl-5 space-y-1.5 text-on-surface-variant leading-relaxed">
                {section.list.map(item => <li>{item}</li>)}
              </ul>
            )}

            {section.items && (
              <div class="space-y-2">
                {section.items.map(item => (
                  <div class="flex flex-col sm:flex-row sm:gap-2 text-on-surface-variant">
                    <span class="font-bold text-on-surface">{item.label}:</span>
                    <span>{item.value}</span>
                  </div>
                ))}
              </div>
            )}

            {section.footer && (
              <p class="mt-4 text-on-surface-variant font-bold">{section.footer}</p>
            )}
          </section>
        ))}
      </div>
    </div>
  </main>
</PageLayout>
