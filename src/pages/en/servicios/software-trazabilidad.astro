---
import { getLang, getAlternates, getBasePath } from '../../../i18n/utils'
import PageLayout from '../../../layouts/PageLayout.astro'
import SoftwareTrazabilidadHeroSection from '../../../sections/SoftwareTrazabilidadHeroSection.astro'
import SoftwareTrazabilidadValueStripSection from '../../../sections/SoftwareTrazabilidadValueStripSection.astro'
import SoftwareTrazabilidadConsisteSection from '../../../sections/SoftwareTrazabilidadConsisteSection.astro'
import SoftwareTrazabilidadGanaSection from '../../../sections/SoftwareTrazabilidadGanaSection.astro'
import SoftwareTrazabilidadCierreSection from '../../../sections/SoftwareTrazabilidadCierreSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="Traceability Software | Azul Sostenible"
  description="Digital traceability for waste management. Real-time control, regulatory compliance and auditable reports for authorities such as SIGERSOL."
>
  <SoftwareTrazabilidadHeroSection lang={lang} />
  <SoftwareTrazabilidadValueStripSection lang={lang} />
  <SoftwareTrazabilidadConsisteSection lang={lang} />
  <SoftwareTrazabilidadGanaSection lang={lang} />
  <SoftwareTrazabilidadCierreSection lang={lang} />
</PageLayout>
