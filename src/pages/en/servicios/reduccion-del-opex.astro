---
import { getLang, getAlternates, getBasePath } from '../../../i18n/utils'
import PageLayout from '../../../layouts/PageLayout.astro'
import ReduccionOpexHeroSection from '../../../sections/ReduccionOpexHeroSection.astro'
import ReduccionOpexPorqueSection from '../../../sections/ReduccionOpexPorqueSection.astro'
import ReduccionOpexMetodologiaSection from '../../../sections/ReduccionOpexMetodologiaSection.astro'
import ReduccionOpexEntregablesSection from '../../../sections/ReduccionOpexEntregablesSection.astro'
import ReduccionOpexBeneficiosSection from '../../../sections/ReduccionOpexBeneficiosSection.astro'
import ReduccionOpexCierreSection from '../../../sections/ReduccionOpexCierreSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="OPEX Reduction | Azul Sostenible"
  description="Strategic environmental OPEX diagnostic. Identify where money is lost and how to recover it with our specialized operational cost reduction methodology."
>
  <ReduccionOpexHeroSection lang={lang} />
  <ReduccionOpexPorqueSection lang={lang} />
  <ReduccionOpexMetodologiaSection lang={lang} />
  <ReduccionOpexEntregablesSection lang={lang} />
  <ReduccionOpexBeneficiosSection lang={lang} />
  <ReduccionOpexCierreSection lang={lang} />
</PageLayout>
