---
import { getLang } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import ProyectosHeroSection from '../../sections/ProyectosHeroSection.astro'
import ProyectosStatsSection from '../../sections/ProyectosStatsSection.astro'
import ProyectosGridSection from '../../sections/ProyectosGridSection.astro'
import ProyectosCierreSection from '../../sections/ProyectosCierreSection.astro'
const lang = getLang(Astro.currentLocale)
---

<PageLayout
  lang={lang}
  title="Projects | Azul Sostenible"
  description="Success stories in the Peruvian mining industry. More than 50 projects executed with 100% regulatory compliance in waste management and technical characterization."
>
  <ProyectosHeroSection lang={lang} />
  <ProyectosStatsSection lang={lang} />
  <ProyectosGridSection lang={lang} />
  <ProyectosCierreSection lang={lang} />
</PageLayout>
