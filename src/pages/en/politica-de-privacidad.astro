---
import { getLang, getAlternates, getBasePath } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'

const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))

const content = {
  title: 'Privacy Policy',
  update: 'Last updated: July 6, 2026',
  intro: 'At Azul Sostenible S.A.C. we respect the privacy of our customers, suppliers and visitors. This Privacy Policy explains how we collect, use, store and protect personal information obtained through our website.',
  sections: [
    {
      heading: '1. Data Controller',
      items: [
        { label: 'Company Name', value: 'Azul Sostenible S.A.C.' },
        { label: 'Tax ID', value: '20612345678' },
        { label: 'Email', value: 'contacto@azulsostenible.pe' },
        { label: 'Website', value: 'www.azulsostenible.pe' },
      ],
    },
    {
      heading: '2. Information We Collect',
      list: [
        'First and last name.',
        'Company or organization.',
        'Position (optional).',
        'Email address.',
        'Phone number.',
        'Address (when necessary).',
        'Information related to quote requests or services.',
        'Any other information provided voluntarily.',
      ],
    },
    {
      heading: '3. Purpose of Processing',
      intro: 'The information collected will be used to:',
      list: [
        'Respond to information requests.',
        'Prepare quotes.',
        'Coordinate technical visits.',
        'Provide advisory on comprehensive waste management.',
        'Manage the provision of our services.',
        'Maintain communication with clients.',
        'Improve our processes.',
        'Comply with legal obligations.',
      ],
    },
    {
      heading: '4. Information Protection',
      body: 'We implement reasonable technical and organizational measures to protect information against unauthorized access, loss, alteration or disclosure.',
    },
    {
      heading: '5. Information Sharing',
      body: 'Azul Sostenible S.A.C. does not sell or trade personal information. Information may only be shared when there is a legal obligation or it is necessary to provide the requested service.',
    },
    {
      heading: '6. Data Retention',
      body: 'Data will be kept only for the time necessary to fulfill the purposes described and applicable legal obligations.',
    },
    {
      heading: '7. Data Subject Rights',
      intro: 'The user may request:',
      list: ['Access', 'Rectification', 'Update', 'Cancellation', 'Opposition'],
      footer: 'Requests may be sent to: contacto@azulsostenible.pe',
    },
    {
      heading: '8. Cookies',
      body: 'Our site may use cookies to improve user experience, obtain browsing statistics and optimize site performance.',
    },
    {
      heading: '9. Third-Party Links',
      body: 'The site may contain links to external pages. Azul Sostenible S.A.C. is not responsible for the privacy policies of such sites.',
    },
    {
      heading: '10. Modifications',
      body: 'We reserve the right to update this Privacy Policy when necessary. Modifications will be published on this same page.',
    },
    {
      heading: '11. Contact',
      items: [
        { label: 'Email', value: 'contacto@azulsostenible.pe' },
        { label: 'Phone', value: '(+51) 936 602 578' },
      ],
    },
  ],
}
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title={'Privacy Policy | Azul Sostenible'}
  description="Privacy policy and personal data protection of Azul Sostenible S.A.C."
>
  <main class="py-section-padding bg-surface">
    <div class="max-w-3xl mx-auto px-6 md:px-margin-desktop">
      <div class="mb-12 md:mb-16">
        <h1 class="font-headline text-3xl md:text-4xl lg:text-5xl text-primary font-extrabold mb-3">
          {content.title}
        </h1>
        <p class="text-on-surface-variant text-sm">{content.update}</p>
      </div>

      <p class="text-on-surface-variant leading-relaxed mb-10">{content.intro}</p>

      <div class="space-y-10">
        {content.sections.map(section => (
          <section>
            <h2 class="font-headline text-xl md:text-2xl text-primary font-bold mb-4">{section.heading}</h2>
            {section.intro && <p class="text-on-surface-variant leading-relaxed mb-4">{section.intro}</p>}
            {section.body && <p class="text-on-surface-variant leading-relaxed">{section.body}</p>}
            {section.list && (
              <ul class="list-disc pl-5 space-y-1.5 text-on-surface-variant leading-relaxed">
                {section.list.map(item => <li>{item}</li>)}
              </ul>
            )}
            {section.items && (
              <div class="space-y-2">
                {section.items.map(item => (
                  <div class="flex flex-col sm:flex-row sm:gap-2 text-on-surface-variant">
                    <span class="font-bold text-on-surface">{item.label}:</span>
                    <span>{item.value}</span>
                  </div>
                ))}
              </div>
            )}
            {section.footer && <p class="mt-4 text-on-surface-variant font-bold">{section.footer}</p>}
          </section>
        ))}
      </div>
    </div>
  </main>
</PageLayout>
