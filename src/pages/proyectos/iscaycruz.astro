---
import { getLang, getAlternates, getBasePath } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import IscaycruzHeroSection from '../../sections/IscaycruzHeroSection.astro'
import IscaycruzBentoSection from '../../sections/IscaycruzBentoSection.astro'
import IscaycruzFAQSection from '../../sections/IscaycruzFAQSection.astro'
import IscaycruzInteresSection from '../../sections/IscaycruzInteresSection.astro'
import IscaycruzCTASection from '../../sections/IscaycruzCTASection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="U.M. ISCAYCRUZ - Caso de Éxito | Azul Sostenible"
  description="Evaluación técnica especializada para la reclasificación de residuos y optimización de procesos industriales en la Unidad Minera Iscaycruz."
>
  <IscaycruzHeroSection lang={lang} />
  <IscaycruzBentoSection lang={lang} />
  <IscaycruzFAQSection lang={lang} />
  <IscaycruzInteresSection lang={lang} />
  <IscaycruzCTASection lang={lang} />
</PageLayout>
