---
import { getLang, getAlternates, getBasePath } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import ChungarHeroSection from '../../sections/ChungarHeroSection.astro'
import ChungarQueHicimosSection from '../../sections/ChungarQueHicimosSection.astro'
import ChungarResolucionSection from '../../sections/ChungarResolucionSection.astro'
import ChungarResumenSection from '../../sections/ChungarResumenSection.astro'
import ChungarFAQSection from '../../sections/ChungarFAQSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="UM. CHUNGAR - Casos de éxito | Azul Sostenible"
  description="Optimizando la gestión de residuos en la Unidad Minera Animón mediante ingeniería ambiental de alta precisión. Cumplimiento total D.L. N° 1278."
>
  <ChungarHeroSection lang={lang} />
  <ChungarQueHicimosSection lang={lang} />
  <ChungarResolucionSection lang={lang} />
  <ChungarResumenSection lang={lang} />
  <ChungarFAQSection lang={lang} />
</PageLayout>
