---
import { getLang } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import AcreditacionesHeroSection from '../../sections/AcreditacionesHeroSection.astro'
import AcreditacionesComplianceSection from '../../sections/AcreditacionesComplianceSection.astro'
import AcreditacionesOperacionesSection from '../../sections/AcreditacionesOperacionesSection.astro'
import AcreditacionesLogisticaSection from '../../sections/AcreditacionesLogisticaSection.astro'
import AcreditacionesHomologacionesSection from '../../sections/AcreditacionesHomologacionesSection.astro'
import AcreditacionesCierreSection from '../../sections/AcreditacionesCierreSection.astro'
const lang = getLang(Astro.currentLocale)
---

<PageLayout
  lang={lang}
  title="Acreditações | Azul Sostenible"
  description="Gestão ambiental respaldada por acreditações oficiais. Conformidade garantida com as normas ambientais vigentes: D.L. 1278, MINAM, MINSA, VIVIENDA e mais."
>
  <AcreditacionesHeroSection lang={lang} />
  <AcreditacionesComplianceSection lang={lang} />
  <AcreditacionesOperacionesSection lang={lang} />
  <AcreditacionesLogisticaSection lang={lang} />
  <AcreditacionesHomologacionesSection lang={lang} />
  <AcreditacionesCierreSection lang={lang} />
</PageLayout>
