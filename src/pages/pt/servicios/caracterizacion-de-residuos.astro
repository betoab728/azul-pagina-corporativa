---
import { getLang, getAlternates, getBasePath } from '../../../i18n/utils'
import PageLayout from '../../../layouts/PageLayout.astro'
import CaracterizacionHeroSection from '../../../sections/CaracterizacionHeroSection.astro'
import CaracterizacionProcesoSection from '../../../sections/CaracterizacionProcesoSection.astro'
import CaracterizacionIncluyeSection from '../../../sections/CaracterizacionIncluyeSection.astro'
import CaracterizacionBeneficiosSection from '../../../sections/CaracterizacionBeneficiosSection.astro'
import CaracterizacionCasoExitoSection from '../../../sections/CaracterizacionCasoExitoSection.astro'
import CaracterizacionCierreSection from '../../../sections/CaracterizacionCierreSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="Caracterização de Resíduos Sólidos | Azul Sostenible"
  description="Serviço profissional de caracterização de resíduos sólidos. Reduza seu custo de disposição final entre 30% e 80% com respaldo normativo."
>
  <CaracterizacionHeroSection lang={lang} />
  <CaracterizacionProcesoSection lang={lang} />
  <CaracterizacionIncluyeSection lang={lang} />
  <CaracterizacionBeneficiosSection lang={lang} />
  <CaracterizacionCasoExitoSection lang={lang} />
  <CaracterizacionCierreSection lang={lang} />
</PageLayout>
