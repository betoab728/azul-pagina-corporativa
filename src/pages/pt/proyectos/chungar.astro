import ChungarQueHicimosSection from '../../../sections/ChungarQueHicimosSection.astro'
import ChungarResolucionSection from '../../../sections/ChungarResolucionSection.astro'
import ChungarResumenSection from '../../../sections/ChungarResumenSection.astro'
import ChungarFAQSection from '../../../sections/ChungarFAQSection.astro'
const lang = getLang(Astro.currentLocale)
---

