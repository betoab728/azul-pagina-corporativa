---
import { getLang } from '../../../i18n/utils'
import PageLayout from '../../../layouts/PageLayout.astro'
import MorocochaHeroSection from '../../../sections/MorocochaHeroSection.astro'
import MorocochaQueHicimosSection from '../../../sections/MorocochaQueHicimosSection.astro'
import MorocochaResolucionSection from '../../../sections/MorocochaResolucionSection.astro'
import MorocochaFAQSection from '../../../sections/MorocochaFAQSection.astro'
import MorocochaCTASection from '../../../sections/MorocochaCTASection.astro'
const lang = getLang(Astro.currentLocale)
---

<PageLayout
  lang={lang}
  title="UM. MOROCOCHA - Caso de Sucesso | Azul Sostenible"
  description="Estudo integral para a avaliação técnica e normativa de embalagens de papelão para explosivos em operações minerárias. Certificação Andeslab e aval do MINAM."
>
  <MorocochaHeroSection lang={lang} />
  <MorocochaQueHicimosSection lang={lang} />
  <MorocochaResolucionSection lang={lang} />
  <MorocochaFAQSection lang={lang} />
  <MorocochaCTASection lang={lang} />
</PageLayout>
