---
import { getLang, getAlternates, getBasePath } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import ContactoHeroSection from '../../sections/ContactoHeroSection.astro'
import ContactoFormSection from '../../sections/ContactoFormSection.astro'
import ContactoCierreSection from '../../sections/ContactoCierreSection.astro'
const lang = getLang(Astro.currentLocale)
const alternates = getAlternates(getBasePath(Astro.url.pathname))
---

<PageLayout
  lang={lang}
  alternates={alternates}
  title="Contato | Azul Sostenible"
  description="Entre em contato conosco para soluções de engenharia ambiental. Sede em Piura, Peru. Solicite uma avaliação gratuita para sua empresa."
>
  <ContactoHeroSection lang={lang} />
  <ContactoFormSection lang={lang} />
  <ContactoCierreSection lang={lang} />
</PageLayout>
