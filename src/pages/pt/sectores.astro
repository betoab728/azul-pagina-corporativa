---
import { getLang } from '../../i18n/utils'
import PageLayout from '../../layouts/PageLayout.astro'
import SectoresHeroSection from '../../sections/SectoresHeroSection.astro'
import SectoresBentoSection from '../../sections/SectoresBentoSection.astro'
import SectoresImpactoSection from '../../sections/SectoresImpactoSection.astro'
import SectoresCierreSection from '../../sections/SectoresCierreSection.astro'
const lang = getLang(Astro.currentLocale)
---

<PageLayout
  lang={lang}
  title="Setores | Azul Sostenible"
  description="Soluções de engenharia ambiental para os setores industrial, minerário, saúde e agroindustrial. Conformidade normativa e gestão técnica especializada por indústria."
>
  <SectoresHeroSection lang={lang} />
  <SectoresBentoSection lang={lang} />
  <SectoresImpactoSection lang={lang} />
  <SectoresCierreSection lang={lang} />
</PageLayout>
