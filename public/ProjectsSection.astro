---
import ProjectCard from '../components/blocks/ProjectCard.astro'
import { projects, whyChooseUs } from '../data/projects'
---

<section id="proyectos" class="py-20 bg-surface-container-low" aria-labelledby="projects-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-margin-desktop">
    <div class="text-center mb-16">
      <span class="text-secondary font-bold text-sm uppercase tracking-widest">PROYECTOS DESTACADOS</span>
      <h2 id="projects-heading" class="font-headline text-4xl md:text-5xl font-extrabold mt-4">
        Conoce algunos de nuestros logros
      </h2>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 items-start">
      <!-- Proyectos destacados -->
      <div class="w-full lg:w-2/3">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {projects.map(project => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>

      <!-- Sidebar: Por qué elegirnos -->
      <aside class="w-full lg:w-1/3 bg-white p-10 rounded-[32px] border border-outline-variant/20 shadow-xl relative overflow-hidden">
        <h3 class="font-headline text-2xl font-extrabold text-primary mb-8 leading-tight">
          ¿Por qué elegir<br />Azul Sostenible?
        </h3>
        <ul class="space-y-4" aria-label="Razones para elegirnos">
          {whyChooseUs.map(reason => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 bg-secondary rounded-full flex items-center justify-center shrink-0 mt-1" aria-hidden="true">
                <span class="material-symbols-outlined text-white text-[10px] font-bold">check</span>
              </div>
              <span class="text-on-surface-variant text-sm font-semibold">{reason}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>
